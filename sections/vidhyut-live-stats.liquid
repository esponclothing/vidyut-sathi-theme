<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
  #shopify-section-{{ section.id }} {
    --bg-white: {{ section.settings.bg_color }};
    --navy: {{ section.settings.text_color_main }};
    --gold-main: {{ section.settings.accent_color }};
    --grid-bg: {{ section.settings.grid_bg_color }};
    --grid-border: {{ section.settings.grid_border_color }};
    --text-muted: {{ section.settings.text_color_muted }};
    --marquee-bg: {{ section.settings.marquee_bg_color }};
    --marquee-text: {{ section.settings.marquee_text_color }};
    --marquee-dot: {{ section.settings.marquee_dot_color }};
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  /* --- CONTAINER --- */
  #shopify-section-{{ section.id }} .network-section-clean {
    position: relative;
    background: var(--bg-white); 
    color: var(--navy);      
    padding: {{ section.settings.padding_top }}px 0 0 0; 
    text-align: center;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .network-content-wrapper {
    padding: 0 20px 60px 20px;
    max-width: 1000px;
    margin: 0 auto;
  }

  /* --- TEXT STYLES --- */
  #shopify-section-{{ section.id }} .network-subtitle {
    color: var(--gold-main); 
    font-weight: 800;
    letter-spacing: 2px;
    margin-bottom: 15px;
    font-size: 0.9rem;
    text-transform: uppercase;
  }
  
  #shopify-section-{{ section.id }} .network-title {
    font-size: 3.5rem;
    font-weight: 900;
    margin-bottom: 50px;
    line-height: 1.1;
    color: var(--navy);
  }

  #shopify-section-{{ section.id }} .net-text, 
  #shopify-section-{{ section.id }} .net-number { 
    display: inline; 
  }

  /* --- STATS GRID --- */
  #shopify-section-{{ section.id }} .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    margin-bottom: 20px;
  }
  
  #shopify-section-{{ section.id }} .stat-item {
    background: var(--grid-bg); 
    border: 1px solid var(--grid-border);
    padding: 30px;
    border-radius: 20px;
    transition: transform 0.3s;
    transform: translateZ(0);
    will-change: transform;
  }
  
  #shopify-section-{{ section.id }} .stat-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  #shopify-section-{{ section.id }} .stat-icon { 
    font-size: 2.5rem; 
    color: var(--gold-main); 
    margin-bottom: 15px; 
  }
  
  #shopify-section-{{ section.id }} .stat-num { 
    font-size: 3rem; 
    font-weight: 800; 
    display: inline-block; 
    color: var(--navy); 
    line-height: 1; 
    font-variant-numeric: tabular-nums; 
    font-feature-settings: "tnum";
    transform: translateZ(0); 
    will-change: contents; 
  }
  
  #shopify-section-{{ section.id }} .stat-label { 
    font-size: 0.9rem; 
    color: var(--text-muted); 
    font-weight: 700; 
    text-transform: uppercase; 
    margin-top: 5px; 
  }

  /* --- MARQUEE STRIP (SEAMLESS FLEXBOX) --- */
  #shopify-section-{{ section.id }} .network-marquee-strip {
    background: var(--marquee-bg); 
    color: var(--marquee-text);
    padding: 15px 0;
    overflow: hidden;
    position: relative;
    border-top: 4px solid var(--gold-main); 
    display: flex;
    white-space: nowrap;
  }
  
  #shopify-section-{{ section.id }} .marquee-track {
    display: flex;
    width: fit-content;
    animation: scrollNetwork-{{ section.id }} {{ section.settings.marquee_speed }}s linear infinite;
    will-change: transform;
  }

  #shopify-section-{{ section.id }} .marquee-content {
    display: flex;
    flex-shrink: 0;
    align-items: center;
  }
  
  #shopify-section-{{ section.id }} .marquee-item {
    display: flex;
    align-items: center;
    font-weight: 700;
    font-size: 0.9rem;
    margin-right: 60px; 
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--marquee-text);
  }

  #shopify-section-{{ section.id }} .live-dot {
    display: inline-block;
    width: 8px; 
    height: 8px;
    background: var(--marquee-dot); 
    border-radius: 50%;
    margin-right: 8px;
    box-shadow: 0 0 8px var(--marquee-dot);
    animation: blink-{{ section.id }} 1.5s infinite;
  }

  @keyframes blink-{{ section.id }} { 
    0% { opacity: 1; } 
    50% { opacity: 0.4; } 
    100% { opacity: 1; } 
  }
  
  @keyframes scrollNetwork-{{ section.id }} {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); } /* Perfectly seamless because we duplicated the track */
  }

  /* --- MOBILE FIXED --- */
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .network-section-clean { 
      padding-top: {{ section.settings.padding_top_mobile }}px !important; 
    }
    
    #shopify-section-{{ section.id }} .network-title { 
      font-size: 2rem; 
      margin-bottom: 30px; 
      display: flex;
      flex-direction: column; 
      gap: 5px; 
      line-height: 1.2;
    }

    #shopify-section-{{ section.id }} .net-text {
      display: block;
      font-size: 1.8rem;
    }

    #shopify-section-{{ section.id }} .net-number {
      display: block;
      font-size: 4rem; 
      color: var(--gold-main); 
      font-weight: 900;
      min-height: 80px; 
    }
    
    #shopify-section-{{ section.id }} .stats-grid { 
      grid-template-columns: repeat(3, 1fr) !important; 
      gap: 10px !important; 
    }
    
    #shopify-section-{{ section.id }} .stat-item { 
      padding: 15px 5px !important; 
      display: block !important; 
      text-align: center !important; 
    }
    
    #shopify-section-{{ section.id }} .stat-icon { 
      font-size: 1.5rem !important; 
      margin-bottom: 5px !important; 
    }
    
    #shopify-section-{{ section.id }} .stat-num { 
      font-size: 1.5rem !important; 
    }
    
    #shopify-section-{{ section.id }} .stat-label { 
      font-size: 0.7rem !important; 
      line-height: 1.1; 
    }
    
    #shopify-section-{{ section.id }} .marquee-item { 
      margin-right: 40px !important; 
      font-size: 0.8rem !important; 
    }
  }
</style>

<div class="network-section-clean" id="network-{{ section.id }}">
  <div class="network-content-wrapper">
    <h5 class="network-subtitle">{{ section.settings.subtitle }}</h5>
    
    <h2 class="network-title">
      <span class="net-text">{{ section.settings.title_part_1 }}</span>
      <span class="net-number"><span class="counter" data-target="{{ section.settings.main_counter_target }}">0</span></span>
      <span class="net-text">{{ section.settings.title_part_2 }}</span>
    </h2>
    
    <div class="stats-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'stat_item' -%}
          <div class="stat-item" {{ block.shopify_attributes }}>
            <div class="stat-icon"><i class="{{ block.settings.icon_class }}"></i></div>
            <div class="stat-num counter" data-target="{{ block.settings.target_number }}">0</div>
            <div class="stat-label">{{ block.settings.label }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="network-marquee-strip">
    <div class="marquee-track">
      <div class="marquee-content">
        {%- for block in section.blocks -%}
          {%- if block.type == 'marquee_order' -%}
            <span class="marquee-item" {{ block.shopify_attributes }}>
              <span class="live-dot"></span> {{ block.settings.order_text }}
            </span>
          {%- endif -%}
        {%- endfor -%}
      </div>
      
      <div class="marquee-content" aria-hidden="true">
        {%- for block in section.blocks -%}
          {%- if block.type == 'marquee_order' -%}
            <span class="marquee-item">
              <span class="live-dot"></span> {{ block.settings.order_text }}
            </span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    // Scope query selector to this specific section to prevent conflicts
    const stats = document.querySelectorAll('#network-{{ section.id }} .counter');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const target = +entry.target.getAttribute('data-target');
          if (!target) return; // Prevent errors if target is missing
          
          const duration = 2000; 
          const increment = target / (duration / 16); 
          
          let current = 0;
          
          const updateCount = () => {
            current += increment;
            
            if (current < target) {
              entry.target.innerText = Math.ceil(current) + "+";
              requestAnimationFrame(updateCount);
            } else {
              entry.target.innerText = target + "+";
            }
          };
          
          updateCount();
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });

    stats.forEach(stat => observer.observe(stat));
  });
</script>

