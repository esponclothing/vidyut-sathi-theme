{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id
-%}

{%- style -%}
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.body_font | font_face: font_display: 'swap' }}

  .by-product-{{ section.id }} {
    --bg-color: {{ section.settings.bg_color }};
    --text-color: {{ section.settings.text_color }};
    --text-light: {{ section.settings.text_color | color_modify: 'alpha', 0.6 }};
    --primary-btn: {{ section.settings.primary_button_color }};
    --primary-btn-text: {{ section.settings.primary_button_text }};
    --border-color: {{ section.settings.border_color }};
    
    /* New Offer Section Colors */
    --offer-section-bg: {{ section.settings.offer_section_bg }};
    --offer-icon-bg: {{ section.settings.offer_icon_bg }};
    --offer-link-color: {{ section.settings.offer_link_color }};
    --offer-badge-bg: {{ section.settings.offer_badge_bg }};
    --offer-copy-color: {{ section.settings.offer_copy_color }};
    
    --font-heading: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
    --font-body: {{ section.settings.body_font.family }}, {{ section.settings.body_font.fallback_families }};

    background-color: var(--bg-color);
    color: var(--text-color);
    font-family: var(--font-body);
    max-width: 768px;
    margin: 0 auto;
    padding-bottom: 110px;
  }

  .by-product-{{ section.id }} * { box-sizing: border-box; }

  /* --- MEDIA GALLERY --- */
  .by-media-gallery { width: 100%; background: #f7f7f7; }
  .by-main-image { width: 100%; aspect-ratio: 4/5; overflow: hidden; position: relative; }
  .by-main-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .by-thumbnails {
    display: flex; gap: 10px; padding: 10px 16px;
    overflow-x: auto; scrollbar-width: none; background: var(--bg-color);
  }
  .by-thumbnails::-webkit-scrollbar { display: none; }
  .by-thumb {
    width: 65px; height: 85px; border-radius: 6px;
    border: 1px solid var(--border-color); overflow: hidden;
    flex-shrink: 0; cursor: pointer;
  }
  .by-thumb.active { border: 2px solid var(--text-color); }
  .by-thumb img { width: 100%; height: 100%; object-fit: cover; }

  /* --- CONTENT AREA & TITLE --- */
  .by-content-wrapper { padding: 20px 16px; }

  .by-title-row {
    display: flex; justify-content: space-between; align-items: flex-start;
    margin-bottom: 12px;
  }
  .by-title-row h1 {
    font-family: var(--font-heading); font-size: 1.4rem; margin: 0;
    font-weight: 700; color: var(--text-color); line-height: 1.3;
  }
  .by-wishlist-btn { background: none; border: none; cursor: pointer; padding: 4px; }
  
  /* --- MAIN PRICING (DYNAMIC) --- */
  .by-price-wrapper { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; transition: opacity 0.2s ease; }
  .by-current-price { font-size: 1.6rem; font-weight: 800; color: var(--text-color); }
  .by-compare-price { font-size: 1.1rem; color: var(--text-light); text-decoration: line-through; }
  .by-save-badge {
    background: #E8F5E9; color: #2E7D32; font-size: 0.8rem;
    font-weight: 700; padding: 4px 8px; border-radius: 4px; text-transform: uppercase;
  }

  /* --- NEW OFFERS SECTION --- */
  .by-offers-section {
    background: var(--offer-section-bg);
    border-radius: 8px;
    padding: 16px 16px 24px 16px;
    margin-bottom: 28px;
  }
  .by-offers-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }
  .by-offers-title {
    display: flex; align-items: center; gap: 10px;
    font-weight: 800; font-size: 1.1rem; color: var(--text-color);
  }
  .by-offer-icon {
    background: var(--offer-icon-bg); color: #fff;
    width: 26px; height: 26px; border-radius: 50%;
    display: flex; justify-content: center; align-items: center;
    font-weight: bold; font-size: 0.9rem;
  }
  .by-offers-link {
    color: var(--offer-link-color); font-size: 0.9rem;
    font-weight: 700; text-decoration: none;
  }
  .by-offers-scroll {
    display: flex; overflow-x: auto; gap: 16px;
    scrollbar-width: none; scroll-snap-type: x mandatory;
    padding-bottom: 12px; /* Space for overlapping badge */
  }
  .by-offers-scroll::-webkit-scrollbar { display: none; }
  .by-offer-card {
    min-width: 280px; max-width: 320px; flex-shrink: 0;
    background: #fff; border: 1.5px dashed #ccc;
    border-radius: 8px; padding: 16px; position: relative;
    scroll-snap-align: start;
  }
  .by-offer-card strong { display: block; font-size: 1.05rem; margin-bottom: 6px; color: var(--text-color); }
  .by-offer-card p { font-size: 0.85rem; color: var(--text-light); margin: 0 0 16px 0; line-height: 1.4; }
  .by-offer-copy {
    background: none; border: none; padding: 0;
    color: var(--offer-copy-color); font-weight: 700; font-size: 0.85rem;
    display: flex; align-items: center; gap: 6px; cursor: pointer;
    text-transform: uppercase;
  }
  .by-offer-copy svg { width: 14px; height: 14px; stroke: currentColor; stroke-width: 2; fill: none; }
  .by-offer-badge {
    position: absolute; right: 16px; bottom: -12px;
    background: var(--offer-badge-bg); color: #fff;
    padding: 4px 10px; border-radius: 4px;
    font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
  }

  /* --- COMBO PACK SELECTION --- */
  .by-section-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 16px; margin-top: 24px;
  }
  .by-section-title { font-weight: 800; font-size: 1.15rem; }
  
  .by-install-btn {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.8rem; font-weight: 600; color: var(--text-color);
    background: #fff; padding: 6px 14px; border-radius: 20px;
    border: 1px solid var(--border-color); text-decoration: none;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05); transition: all 0.2s ease;
  }
  .by-install-btn:hover { border-color: var(--text-color); }
  
  .by-combo-grid { display: flex; flex-direction: column; gap: 14px; }
  .by-combo-card {
    display: flex; justify-content: space-between; align-items: center; gap: 16px;
    border: 1.5px solid var(--border-color); padding: 18px 16px; 
    border-radius: 10px; cursor: pointer; position: relative;
    background: #fff; transition: all 0.3s ease;
  }
  .by-combo-card:hover { border-color: #ccc; }
  .by-combo-card.active {
    border-color: var(--primary-btn); background: #FFFAEB;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  }
  
  .by-combo-left { display: flex; align-items: center; gap: 12px; }
  .by-combo-radio {
    width: 24px; height: 24px; border-radius: 50%;
    border: 2px solid #ccc; position: relative; flex-shrink: 0;
  }
  .by-combo-card.active .by-combo-radio { border-color: var(--primary-btn); }
  .by-combo-card.active .by-combo-radio::after {
    content: ''; position: absolute; top: 4px; left: 4px; right: 4px; bottom: 4px;
    background: var(--primary-btn); border-radius: 50%;
  }
  
  .by-combo-info { display: flex; flex-direction: column; gap: 3px; }
  .by-combo-title { font-weight: 800; font-size: 1.05rem; color: var(--text-color); }
  .by-combo-desc { font-size: 0.85rem; color: var(--text-light); }

  .by-combo-right { display: flex; flex-direction: column; align-items: flex-end; text-align: right; }
  .by-combo-price { font-weight: 800; font-size: 1.15rem; color: var(--text-color); }
  .by-combo-compare { font-size: 0.85rem; color: var(--text-light); text-decoration: line-through; margin-bottom: 2px; }
  
  .by-combo-badge {
    position: absolute; left: 16px; top: -10px; 
    background: var(--primary-btn); color: var(--primary-btn-text);
    font-size: 0.75rem; font-weight: 800; padding: 4px 12px;
    border-radius: 20px; text-transform: uppercase;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  /* --- DELIVERY & ACCORDIONS --- */
  .by-delivery-wrapper { margin-top: 36px; }
  .by-delivery-input-group { display: flex; border: 1px solid var(--border-color); border-radius: 8px; overflow: hidden; }
  .by-delivery-input-group input { flex: 1; padding: 16px; border: none; outline: none; font-family: inherit; }
  .by-delivery-input-group button { background: var(--text-color); color: var(--bg-color); border: none; padding: 0 24px; font-weight: bold; cursor: pointer; }

  .by-details-container { margin-top: 36px; }
  .by-accordion { border-bottom: 1px solid var(--border-color); }
  .by-accordion:first-of-type { border-top: 1px solid var(--border-color); }
  .by-accordion summary { padding: 18px 0; font-weight: 700; cursor: pointer; list-style: none; display: flex; justify-content: space-between; }
  .by-accordion summary::-webkit-details-marker { display: none; }
  .by-accordion summary::after { content: '+'; font-size: 1.4rem; transition: transform 0.3s; }
  .by-accordion[open] summary::after { transform: rotate(45deg); }
  .by-accordion-content { padding-bottom: 18px; font-size: 0.95rem; color: var(--text-light); line-height: 1.6; }

  /* --- STICKY BOTTOM ACTIONS --- */
  .by-sticky-bar {
    position: fixed; bottom: 0; left: 0; right: 0;
    background: var(--bg-color); padding: 16px;
    box-shadow: 0 -10px 30px rgba(0,0,0,0.08); display: flex; z-index: 999;
    max-width: 768px; margin: 0 auto; border-top: 1px solid var(--border-color);
  }
  .by-btn-add {
    width: 100%; padding: 18px; border: none; border-radius: 8px;
    font-weight: 800; font-size: 1.15rem; cursor: pointer;
    text-transform: uppercase; letter-spacing: 1px;
    background: var(--primary-btn); color: var(--primary-btn-text);
    box-shadow: 0 4px 15px rgba(0,0,0,0.1); transition: transform 0.2s ease;
    display: flex; justify-content: center; align-items: center; gap: 8px;
  }
  .by-btn-add:active { transform: scale(0.98); }
  .by-btn-add.loading { opacity: 0.8; pointer-events: none; }

  @media (min-width: 769px) {
    .by-sticky-bar { position: sticky; bottom: 20px; border-radius: 12px; border: 1px solid var(--border-color); }
    .by-product-{{ section.id }} { padding-bottom: 20px; }
  }
{%- endstyle -%}

<div class="by-product-{{ section.id }}">
  
  <div class="by-media-gallery">
    <div class="by-main-image">
      {%- if product.featured_media -%}
        <img src="{{ product.featured_media | img_url: '800x' }}" alt="{{ product.title | escape }}">
      {%- else -%}
        <div style="width: 100%; height: 100%; background: #e0e0e0; display:flex; align-items:center; justify-content:center; color: #666;">Product Image</div>
      {%- endif -%}
    </div>
  </div>

  <div class="by-content-wrapper">
    
    <!-- SHOPIFY NATIVE FORM -->
    {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
      
      <div class="by-title-row">
        <h1>{{ product.title | default: 'Premium Modular Pack' }}</h1>
      </div>

      <!-- Top Master Pricing Display -->
      <div class="by-price-wrapper" id="MainPriceWrapper-{{ section.id }}">
        <span class="by-current-price" id="TopPrice-{{ section.id }}">
          {{ current_variant.price | default: 199900 | money }}
        </span>
        
        <span class="by-compare-price" id="TopComparePrice-{{ section.id }}" {% unless current_variant.compare_at_price > current_variant.price %}style="display:none;"{% endunless %}>
          {{ current_variant.compare_at_price | money }}
        </span>
        
        {%- assign top_save_percent = 0 -%}
        {%- if current_variant.compare_at_price > current_variant.price -%}
          {%- assign top_save_percent = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round -%}
        {%- endif -%}
        <span class="by-save-badge" id="TopSaveBadge-{{ section.id }}" {% if top_save_percent == 0 %}style="display:none;"{% endif %}>
          Save {{ top_save_percent }}%
        </span>
      </div>

      <!-- OFFERS & DISCOUNTS SECTION -->
      {%- assign has_offers = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'offer' -%}{%- assign has_offers = true -%}{%- break -%}{%- endif -%}
      {%- endfor -%}

      {%- if has_offers -%}
        <div class="by-offers-section">
          <div class="by-offers-header">
            <div class="by-offers-title">
              <span class="by-offer-icon">%</span>
              Offers & Discounts
            </div>
            {%- if section.settings.offer_link_url != blank -%}
              <a href="{{ section.settings.offer_link_url }}" class="by-offers-link">{{ section.settings.offer_link_text }}</a>
            {%- else -%}
              <span class="by-offers-link" style="cursor: pointer;">{{ section.settings.offer_link_text }}</span>
            {%- endif -%}
          </div>
          
          <div class="by-offers-scroll">
            {%- for block in section.blocks -%}
              {%- if block.type == 'offer' -%}
                <div class="by-offer-card" {{ block.shopify_attributes }}>
                  <strong>{{ block.settings.title }}</strong>
                  <p>{{ block.settings.subtitle }}</p>
                  
                  <button type="button" class="by-offer-copy" data-code="{{ block.settings.code }}">
                    <svg viewBox="0 0 24 24"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg>
                    <span>CLICK TO COPY</span>
                  </button>

                  {%- if block.settings.badge_text != blank -%}
                    <div class="by-offer-badge">{{ block.settings.badge_text }}</div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      <div class="by-section-header">
        <span class="by-section-title">Select Pack Options</span>
        {%- if section.settings.install_guide_link != blank -%}
          <a href="{{ section.settings.install_guide_link }}" class="by-install-btn" target="_blank">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
            {{ section.settings.install_guide_text }}
          </a>
        {%- endif -%}
      </div>
      
      <!-- DYNAMIC VARIANTS LOOP -->
      <div class="by-combo-grid" id="ComboGrid-{{ section.id }}">
        <!-- Hidden Input for Cart -->
        <input type="hidden" name="id" id="SelectedVariantID-{{ section.id }}" value="{{ current_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        
        {%- for variant in product.variants -%}
          
          {%- assign save_percent = 0 -%}
          {%- if variant.compare_at_price > variant.price -%}
            {%- assign save_percent = variant.compare_at_price | minus: variant.price | times: 100.0 | divided_by: variant.compare_at_price | round -%}
          {%- endif -%}

          {%- assign custom_subtitle = '' -%}
          {%- assign custom_badge = '' -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'variant_meta' and block.settings.variant_title == variant.title -%}
              {%- assign custom_subtitle = block.settings.subtitle -%}
              {%- assign custom_badge = block.settings.custom_badge -%}
            {%- endif -%}
          {%- endfor -%}

          <label class="by-combo-card {% if variant.id == current_variant.id %}active{% endif %}">
            
            <input 
              type="radio" 
              name="combo_selector_radio" 
              value="{{ variant.id }}" 
              {% if variant.id == current_variant.id %}checked{% endif %} 
              data-price="{{ variant.price | money | escape }}"
              data-compare="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money | escape }}{% endif %}"
              data-save="{% if save_percent > 0 %}{{ save_percent }}{% endif %}"
              style="display:none;"
            >
            
            {%- if custom_badge != blank -%}
              <span class="by-combo-badge">{{ custom_badge }}</span>
            {%- elsif save_percent > 0 -%}
              <span class="by-combo-badge">Save {{ save_percent }}%</span>
            {%- endif -%}

            <div class="by-combo-left">
              <div class="by-combo-radio"></div>
              <div class="by-combo-info">
                <span class="by-combo-title">{{ variant.title }}</span>
                {%- if custom_subtitle != blank -%}
                  <span class="by-combo-desc">{{ custom_subtitle }}</span>
                {%- endif -%}
              </div>
            </div>
            
            <div class="by-combo-right">
              {%- if variant.compare_at_price > variant.price -%}
                <span class="by-combo-compare">{{ variant.compare_at_price | money }}</span>
              {%- endif -%}
              <span class="by-combo-price">{{ variant.price | money }}</span>
            </div>
          </label>
        {%- endfor -%}
        
        {%- if product.variants.size == 0 -%}
          <label class="by-combo-card active">
            <input type="radio" name="id" checked style="display:none;">
            <div class="by-combo-left">
              <div class="by-combo-radio"></div>
              <div class="by-combo-info"><span class="by-combo-title">Default Product</span></div>
            </div>
            <div class="by-combo-right"><span class="by-combo-price">₹1999</span></div>
          </label>
        {%- endif -%}
      </div>

      <!-- Check Delivery -->
      {%- if section.settings.enable_delivery_check -%}
      <div class="by-delivery-wrapper">
        <div class="by-section-title" style="margin-bottom: 12px;">Check Delivery Availability</div>
        <div class="by-delivery-input-group">
          <input type="text" placeholder="Enter Pincode / Zip Code">
          <button type="button">Check</button>
        </div>
      </div>
      {%- endif -%}

      <div class="by-details-container">
        <details class="by-accordion" open>
          <summary>Product Description</summary>
          <div class="by-accordion-content">{{ product.description | default: 'Experience premium quality.' }}</div>
        </details>
        <details class="by-accordion">
          <summary>Returns & Exchange</summary>
          <div class="by-accordion-content">Easy 15 days return and exchange policy available.</div>
        </details>
      </div>

      <!-- Submit Button -->
      <div class="by-sticky-bar">
        <button class="by-btn-add" type="submit" name="add" id="SubmitBtn-{{ section.id }}">
          <span>Add to Cart</span> 
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 6px;"><path d="M5 12h14"></path><path d="M12 5l7 7-7 7"></path></svg>
        </button>
      </div>

    {%- endform -%}

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // 1. Combo Selection Logic
    const grid = document.getElementById('ComboGrid-{{ section.id }}');
    const mainVariantInput = document.getElementById('SelectedVariantID-{{ section.id }}');
    const topPrice = document.getElementById('TopPrice-{{ section.id }}');
    const topCompare = document.getElementById('TopComparePrice-{{ section.id }}');
    const topSaveBadge = document.getElementById('TopSaveBadge-{{ section.id }}');
    const priceWrapper = document.getElementById('MainPriceWrapper-{{ section.id }}');

    if(grid) {
      const cards = grid.querySelectorAll('.by-combo-card');
      cards.forEach(card => {
        card.addEventListener('click', function() {
          cards.forEach(c => c.classList.remove('active'));
          this.classList.add('active');
          
          const radio = this.querySelector('input[type="radio"]');
          if(radio) {
            radio.checked = true;
            if(mainVariantInput) {
              mainVariantInput.value = radio.value;
            }
            
            priceWrapper.style.opacity = '0';
            setTimeout(() => {
              if(topPrice && radio.dataset.price) topPrice.innerHTML = radio.dataset.price;
              
              if(topCompare) {
                if(radio.dataset.compare) {
                  topCompare.innerHTML = radio.dataset.compare;
                  topCompare.style.display = 'inline-block';
                } else {
                  topCompare.style.display = 'none';
                }
              }

              if(topSaveBadge) {
                if(radio.dataset.save) {
                  topSaveBadge.innerHTML = 'Save ' + radio.dataset.save + '%';
                  topSaveBadge.style.display = 'inline-block';
                } else {
                  topSaveBadge.style.display = 'none';
                }
              }
              priceWrapper.style.opacity = '1';
            }, 150);
          }
        });
      });
    }

    // 2. Copy Coupon Logic
    const copyBtns = document.querySelectorAll('.by-offer-copy');
    copyBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        const code = this.getAttribute('data-code');
        const span = this.querySelector('span');
        
        if(navigator.clipboard && window.isSecureContext) {
          navigator.clipboard.writeText(code).then(() => {
            span.innerText = 'COPIED!';
            setTimeout(() => { span.innerText = 'CLICK TO COPY'; }, 2000);
          });
        } else {
          // Fallback
          const textArea = document.createElement("textarea");
          textArea.value = code;
          document.body.appendChild(textArea);
          textArea.select();
          document.execCommand("copy");
          textArea.remove();
          span.innerText = 'COPIED!';
          setTimeout(() => { span.innerText = 'CLICK TO COPY'; }, 2000);
        }
      });
    });

    // 3. Button Loading State
    const form = document.getElementById('{{ product_form_id }}');
    const btn = document.getElementById('SubmitBtn-{{ section.id }}');
    if(form && btn) {
      form.addEventListener('submit', function() {
        btn.classList.add('loading');
        btn.querySelector('span').innerText = 'Adding...';
        setTimeout(() => { 
          btn.classList.remove('loading'); 
          btn.querySelector('span').innerText = 'Add to Cart'; 
        }, 2000);
      });
    }
  });
</script>

{% schema %}
{
  "name": "Combo Product Info",
  "settings": [
    {
      "type": "header",
      "content": "Base Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#EAEAEA"
    },
    {
      "type": "color",
      "id": "primary_button_color",
      "label": "Add To Cart / Accent Color",
      "default": "#D4A373"
    },
    {
      "type": "color",
      "id": "primary_button_text",
      "label": "Button Text Color",
      "default": "#FFFFFF"
    },
    {
