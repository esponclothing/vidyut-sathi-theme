{%- liquid
  assign current_variant = product.selected_or_first_available_variant
-%}

{%- style -%}
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.body_font | font_face: font_display: 'swap' }}

  .ht-product-{{ section.id }} {
    --bg-main: {{ section.settings.bg_color }};
    --panel-bg: {{ section.settings.panel_bg_color }};
    --text-main: {{ section.settings.text_color }};
    --text-muted: {{ section.settings.text_color | color_modify: 'alpha', 0.6 }};
    --accent: {{ section.settings.accent_color }};
    --accent-glow: {{ section.settings.accent_color | color_modify: 'alpha', 0.15 }};
    --border-color: {{ section.settings.border_color }};
    
    --font-heading: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
    --font-body: {{ section.settings.body_font.family }}, {{ section.settings.body_font.fallback_families }};
    --radius: {{ section.settings.border_radius }}px;

    background-color: var(--bg-main);
    color: var(--text-main);
    font-family: var(--font-body);
    padding: 20px;
    max-width: 100%;
    margin: 0 auto;
    position: relative;
    padding-bottom: 120px; /* Space for sticky bottom buttons */
    box-sizing: border-box;
  }

  .ht-product-{{ section.id }} * {
    box-sizing: border-box;
  }

  /* Typography */
  .ht-product-{{ section.id }} h1, 
  .ht-product-{{ section.id }} h2, 
  .ht-product-{{ section.id }} h3 {
    font-family: var(--font-heading);
    margin: 0 0 10px 0;
    color: var(--text-main);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ht-reviews-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    margin-bottom: 24px;
    color: var(--text-muted);
  }

  .ht-reviews-badge .star {
    color: var(--accent);
    font-weight: bold;
    text-shadow: 0 0 8px var(--accent-glow);
  }

  /* High-Tech Offers Scroller */
  .ht-offer-scroll {
    display: flex;
    overflow-x: auto;
    gap: 16px;
    padding-bottom: 16px;
    scrollbar-width: none;
    margin-bottom: 24px;
  }
  .ht-offer-scroll::-webkit-scrollbar { display: none; }
  
  .ht-offer-card {
    min-width: 280px;
    background: var(--panel-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    padding: 16px;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
  }
  .ht-offer-card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 20px var(--accent-glow) inset;
  }
  .ht-offer-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 3px; height: 100%;
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
  }
  .ht-offer-badge {
    display: inline-block;
    background: var(--accent-glow);
    color: var(--accent);
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: bold;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: 1px solid var(--accent);
  }
  .ht-offer-code {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px dashed var(--border-color);
    font-size: 0.85rem;
  }

  /* Variant Selection (Colors & Sizes) */
  .ht-variant-group {
    margin-bottom: 30px;
  }
  .ht-variant-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 16px;
  }
  .ht-variant-title {
    font-size: 1rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .ht-guide-link {
    color: var(--accent);
    text-decoration: none;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: text-shadow 0.3s ease;
    text-transform: uppercase;
    font-weight: bold;
  }
  .ht-guide-link:hover {
    text-shadow: 0 0 10px var(--accent);
  }
  
  /* Size Grid */
  .ht-size-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .ht-size-box {
    border: 1px solid var(--border-color);
    background: var(--panel-bg);
    padding: 12px 16px;
    border-radius: var(--radius);
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: center;
    min-width: 60px;
    font-weight: bold;
    color: var(--text-muted);
    position: relative;
    overflow: hidden;
  }
  .ht-size-box:hover, .ht-size-box.active {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-glow);
    box-shadow: 0 0 15px var(--accent-glow);
  }

  /* Pincode / Delivery Check */
  .ht-delivery-box {
    display: flex;
    background: var(--panel-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.3s ease;
  }
  .ht-delivery-box:focus-within {
    border-color: var(--accent);
  }
  .ht-delivery-box input {
    flex-grow: 1;
    background: transparent;
    border: none;
    padding: 16px;
    color: var(--text-main);
    outline: none;
    font-family: inherit;
  }
  .ht-delivery-box button {
    background: var(--text-main);
    color: var(--bg-main);
    border: none;
    padding: 0 24px;
    cursor: pointer;
    font-weight: bold;
    text-transform: uppercase;
    transition: background 0.3s ease, color 0.3s ease;
  }
  .ht-delivery-box button:hover {
    background: var(--accent);
    color: #000;
  }
  .ht-delivery-perks {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 12px;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  /* Reward Banner */
  .ht-reward-banner {
    background: linear-gradient(90deg, var(--panel-bg), var(--accent-glow));
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    padding: 16px;
    margin: 30px 0;
    display: flex;
    align-items: center;
    gap: 16px;
    font-weight: bold;
    box-shadow: 0 0 20px var(--accent-glow);
  }

  /* Accordions (Specifications, Details, etc.) */
  .ht-accordion-group {
    border-top: 1px solid var(--border-color);
    margin-bottom: 30px;
  }
  .ht-accordion {
    border-bottom: 1px solid var(--border-color);
  }
  .ht-accordion summary {
    padding: 20px 0;
    cursor: pointer;
    font-weight: bold;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-heading);
    letter-spacing: 0.5px;
    transition: color 0.3s ease;
  }
  .ht-accordion summary:hover {
    color: var(--accent);
  }
  .ht-accordion summary::-webkit-details-marker { display: none; }
  .ht-accordion summary::after {
    content: '+';
    color: var(--accent);
    font-size: 1.5rem;
    font-weight: normal;
    transition: transform 0.3s ease;
  }
  .ht-accordion[open] summary::after {
    transform: rotate(45deg);
  }
  .ht-accordion-content {
    padding-bottom: 20px;
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* Trust Badges */
  .ht-trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    text-align: center;
    margin: 40px 0;
    padding: 20px 0;
    border-top: 1px dashed var(--border-color);
    border-bottom: 1px dashed var(--border-color);
  }
  .ht-trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .ht-trust-item svg {
    width: 36px;
    height: 36px;
    stroke: var(--accent);
    fill: none;
    filter: drop-shadow(0 0 5px var(--accent-glow));
  }
  .ht-trust-item span {
    font-size: 0.8rem;
    font-weight: bold;
    color: var(--text-main);
    text-transform: uppercase;
  }

  /* Sticky Action Buttons */
  .ht-sticky-actions {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    background: rgba(15, 15, 19, 0.85); /* Dark transparent base */
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid var(--accent);
    padding: 16px;
    display: flex;
    gap: 12px;
    z-index: 999;
    box-shadow: 0 -10px 40px rgba(0,0,0,0.6);
  }
  .ht-btn {
    flex: 1;
    padding: 16px;
    border: none;
    border-radius: var(--radius);
    font-weight: bold;
    font-size: 1rem;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.2s ease;
    font-family: var(--font-heading);
  }
  .ht-btn:active { transform: scale(0.98); }
  
  .ht-btn-secondary {
    background: transparent;
    color: var(--text-main);
    border: 1px solid var(--border-color);
  }
  .ht-btn-secondary:hover {
    border-color: var(--text-main);
  }
  
  .ht-btn-primary {
    background: var(--accent);
    color: #000;
    box-shadow: 0 0 15px var(--accent-glow);
  }
  .ht-btn-primary:hover {
    box-shadow: 0 0 25px var(--accent);
    filter: brightness(1.1);
  }

  @media (min-width: 750px) {
    .ht-sticky-actions {
      position: sticky;
      bottom: 20px;
      border: 1px solid var(--accent);
      border-radius: var(--radius);
      margin-top: 40px;
      width: 100%;
    }
    .ht-product-{{ section.id }} {
      padding-bottom: 20px;
    }
  }
{%- endstyle -%}

<div class="ht-product-{{ section.id }}">
  
  <!-- Title & Reviews -->
  <h1>{{ product.title | default: 'System Core Module v2.0' }}</h1>
  <div class="ht-reviews-badge">
    <span class="star">★ {{ section.settings.review_score | default: '5.0' }}</span>
    <span>({{ section.settings.review_count | default: '32' }} ratings)</span>
    <span style="color: var(--accent); margin-left: auto; font-size: 0.8rem; text-transform: uppercase;">Verified Build</span>
  </div>

  <!-- Offers Section -->
  {%- if section.blocks.size > 0 -%}
    <div class="ht-offer-scroll">
      {%- for block in section.blocks -%}
        {%- if block.type == 'offer' -%}
          <div class="ht-offer-card" {{ block.shopify_attributes }}>
            <div class="ht-offer-badge">Discount Protocol Active</div>
            <strong style="display: block; font-size: 1.1rem; margin-bottom: 6px;">{{ block.settings.title }}</strong>
            <p style="margin: 0; color: var(--text-muted); font-size: 0.85rem;">{{ block.settings.subtitle }}</p>
            <div class="ht-offer-code">
              <span>Apply at checkout</span>
              <strong style="color: var(--accent);">Code: {{ block.settings.code }}</strong>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  <!-- Configuration (Variants) -->
  <variant-radios class="no-js-hidden" data-section="{{ section.id }}" data-url="{{ product.url }}">
    
    <!-- Size Selection & Installation Guide -->
    <div class="ht-variant-group">
      <div class="ht-variant-header">
        <span class="ht-variant-title">Select Parameters</span>
        {%- if section.settings.install_guide_link != blank -%}
          <a href="{{ section.settings.install_guide_link }}" class="ht-guide-link" target="_blank">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
            {{ section.settings.install_guide_text }}
          </a>
        {%- endif -%}
      </div>
      
      <!-- Placeholder for sizes to match image -->
      <div class="ht-size-grid">
        <div class="ht-size-box">S</div>
        <div class="ht-size-box active">M</div>
        <div class="ht-size-box">L</div>
        <div class="ht-size-box">XL</div>
        <div class="ht-size-box">XXL</div>
      </div>
    </div>
  </variant-radios>

  <!-- Delivery Check -->
  {%- if section.settings.enable_delivery_check -%}
  <div class="ht-variant-group">
    <div class="ht-variant-title" style="margin-bottom: 12px;">Check Network Routing (Delivery)</div>
    <div class="ht-delivery-box">
      <input type="text" placeholder="Enter Pincode / Zip Code">
      <button type="button">Check</button>
    </div>
    <div class="ht-delivery-perks">
      <div style="display: flex; gap: 8px; align-items: center;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
        <span>Free Shipping Routing</span>
      </div>
      <div style="display: flex; gap: 8px; align-items: center;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        <span>Secure Protocol (COD Available)</span>
      </div>
    </div>
  </div>
  {%- endif -%}

  <!-- Reward Banner -->
  {%- if section.settings.enable_rewards -%}
  <div class="ht-reward-banner">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--bg-main)" stroke-width="2" style="background: var(--accent); padding: 4px; border-radius: 4px;"><polyline points="20 12 20 22 4 22 4 12"></polyline><rect x="2" y="7" width="20" height="5"></rect><line x1="12" y1="22" x2="12" y2="7"></line><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path></svg>
    <div>
      System Reward: Earn <span style="color: var(--accent);">{{ section.settings.reward_percentage }}%</span> creds on this synchronization.
    </div>
  </div>
  {%- endif -%}

  <!-- Accordions -->
  <div class="ht-accordion-group">
    {%- for block in section.blocks -%}
      {%- if block.type == 'accordion' -%}
        <details class="ht-accordion" {{ block.shopify_attributes }}>
          <summary>{{ block.settings.heading }}</summary>
          <div class="ht-accordion-content">
            {{ block.settings.content }}
          </div>
        </details>
      {%- endif -%}
    {%- endfor -%}
    
    <!-- Hardcoded Description Fallback -->
    <details class="ht-accordion">
      <summary>System Specifications</summary>
      <div class="ht-accordion-content">
        {{ product.description | default: 'Detailed schematics and modular information for this unit.' }}
      </div>
    </details>
  </div>

  <!-- Trust Badges -->
  <div class="ht-trust-grid">
    <div class="ht-trust-item">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><path d="M9 12l2 2 4-4"></path></svg>
      <span>Original<br>Hardware</span>
    </div>
    <div class="ht-trust-item">
      <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
      <span>3M+ Active<br>Nodes</span>
    </div>
    <div class="ht-trust-item">
      <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
      <span>Premium<br>Grade</span>
    </div>
  </div>

  <!-- Sticky Actions (Replaces sticky-add-to-cart logic) -->
  <div class="ht-sticky-actions">
    <button class="ht-btn ht-btn-secondary" type="button">Add to Array</button>
    <button class="ht-btn ht-btn-primary" type="button">Execute Buy</button>
  </div>

</div>

{% schema %}
{
  "name": "High-Tech Product Data",
  "settings": [
    {
      "type": "header",
      "content": "Cyber Theme Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Main Background",
      "default": "#0b0b0e"
    },
    {
      "type": "color",
      "id": "panel_bg_color",
      "label": "Panel Background",
      "default": "#14141a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#e2e8f0"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Neon Accent Color",
      "default": "#00ffcc"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#2d2d3b"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Element Corner Radius",
      "default": 4
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading Font",
      "default": "mono"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body Font",
      "default": "sans-serif"
    },
    {
      "type": "header",
      "content": "Installation Guide"
    },
    {
      "type": "text",
      "id": "install_guide_text",
      "label": "Link Text",
      "default": "Installation Guide"
    },
    {
      "type": "url",
      "id": "install_guide_link",
      "label": "Guide URL"
    },
    {
      "type": "header",
      "content": "Features & Toggles"
    },
    {
      "type": "checkbox",
      "id": "enable_delivery_check",
      "label": "Enable Pincode/Delivery Check",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_rewards",
      "label": "Enable Reward Banner",
      "default": true
    },
    {
      "type": "text",
      "id": "reward_percentage",
      "label": "Reward Percentage",
      "default": "10"
    },
    {
      "type": "text",
      "id": "review_score",
      "label": "Dummy Review Score",
      "default": "5.0"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Dummy Review Count",
      "default": "32"
    }
  ],
  "blocks": [
    {
      "type": "offer",
      "name": "Discount Protocol (Offer)",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Offer Title",
          "default": "Get Flat 5% OFF"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Condition Details",
          "default": "Add items worth ₹1999+ to unlock this offer"
        },
        {
          "type": "text",
          "id": "code",
          "label": "Coupon Code",
          "default": "CYBER5"
        }
      ]
    },
    {
      "type": "accordion",
      "name": "Data Accordion",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Technical Specifications"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Fabric: Imported Poly<br>Fit: Ergonomic Regular</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "High-Tech Product Data",
      "blocks": [
        { "type": "offer" },
        { "type": "accordion" },
        { "type": "accordion" }
      ]
    }
  ]
}
{% endschema %}