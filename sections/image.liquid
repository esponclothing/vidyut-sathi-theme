{%- style -%}
  .animated-book-section-{{ section.id }} {
    padding: 30px 15px;
    background-color: {{ section.settings.section_bg_color }};
    text-align: center;
  }

  .animated-book-section-{{ section.id }} .heading-text {
    color: #000;
    font-weight: bold;
    font-size: 20px;
    margin-bottom: 20px;
  }

  /* Flexbox wrapper to keep hands perfectly glued to the button */
  .animated-book-wrapper-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px; /* Space between hands and button */
    margin: 0 auto;
  }

  /* Button Styling - widths removed so it hugs the text */
  .animated-book-btn-{{ section.id }} {
    background-color: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};
    padding: 12px 40px;
    border-radius: 30px;
    text-decoration: none;
    font-weight: bold;
    font-size: 18px;
    transition: opacity 0.3s ease;
    display: inline-block;
    white-space: nowrap; /* Prevents text from wrapping to a second line */
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  }

  .animated-book-btn-{{ section.id }}:hover {
    opacity: 0.85;
    color: {{ section.settings.button_text_color }};
  }

  /* Icon Styling and Animation */
  .animated-book-icon-{{ section.id }} {
    color: {{ section.settings.icon_color }};
    width: 35px; /* Slightly larger to accommodate the wide SVG shape */
    height: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .animated-book-icon-{{ section.id }} svg {
    width: 100%;
    height: 100%;
    fill: currentColor; /* Forces the SVG to take the schema color */
  }

  .icon-left-{{ section.id }} {
    animation: moveRight-{{ section.id }} {{ section.settings.animation_speed }}s infinite alternate ease-in-out;
  }

  .icon-right-{{ section.id }} {
    animation: moveLeft-{{ section.id }} {{ section.settings.animation_speed }}s infinite alternate ease-in-out;
  }

  @keyframes moveRight-{{ section.id }} {
    0% { transform: translateX(-8px); }
    100% { transform: translateX(8px); }
  }

  @keyframes moveLeft-{{ section.id }} {
    0% { transform: translateX(8px); }
    100% { transform: translateX(-8px); }
  }

  @media (max-width: 480px) {
    .animated-book-wrapper-{{ section.id }} {
      gap: 10px;
    }
    .animated-book-btn-{{ section.id }} {
      padding: 10px 20px;
      font-size: 16px;
    }
    .animated-book-icon-{{ section.id }} {
      width: 28px;
      height: 28px;
    }
  }
{%- endstyle -%}

<div class="animated-book-section-{{ section.id }}">
  {%- if section.settings.heading_text != blank -%}
    <h4 class="heading-text">{{ section.settings.heading_text }}</h4>
  {%- endif -%}

