<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;600;700;800;900&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">

<style>
  /* ── Vidhyut Saathi Base & Typography ── */
  .business-section-{{ section.id }} * { box-sizing: border-box; }
  .business-section-{{ section.id }} {
    margin: 0;
    font-family: 'Nunito', sans-serif;
    background: #FAFAF7; /* VS Main Background */
    overflow-x: hidden;
    color: #222222;
    padding: 80px 20px;
    background: radial-gradient(circle at top right, rgba(247,148,29,0.05), transparent 40%), linear-gradient(180deg, #FAFAF7 0%, #FFFFFF 100%);
    position: relative;
  }
  
  .business-section-{{ section.id }} .container {
    max-width: 1200px;
    margin: auto;
    position: relative;
    z-index: 2;
  }

  /* ── HEADER ── */
  .business-section-{{ section.id }} .heading {
    text-align: center;
    margin-bottom: 52px !important;
  }

  .business-section-{{ section.id }} .heading h1 {
    margin: 0;
    font-family: 'Baloo 2', sans-serif !important;
    font-size: clamp(3.5rem, 12vw, 6.5rem) !important;
    font-weight: 900 !important;
    line-height: 1 !important;
    letter-spacing: -2px !important;
    text-transform: uppercase !important;
    text-align: center !important;
    background: linear-gradient(90deg, #E07810 0%, #F7941D 55%, #FDB44B 100%) !important;
    -webkit-background-clip: text !important;
    -webkit-text-fill-color: transparent !important;
    filter: drop-shadow(0 10px 20px rgba(247,148,29,.18));
  }

  .business-section-{{ section.id }} .heading h1 span {
    display: none !important;
  }

  .business-section-{{ section.id }} .glow-line {
    width: 240px !important;
    height: 7px !important;
    border-radius: 999px !important;
    margin: 18px auto 0 !important;
    background: linear-gradient(90deg, #F7941D, #FDB44B, #3EAD47) !important;
    box-shadow: 0 0 20px rgba(247,148,29,.30) !important;
  }

  /* ── CARDS GRID ── */
  .business-section-{{ section.id }} .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
    align-items: stretch;
  }

  .business-section-{{ section.id }} .card {
    background: #ffffff;
    border-radius: 24px;
    padding: 32px 24px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    backdrop-filter: blur(10px);
    border: 1.5px solid rgba(247,148,29,.08) !important;
    box-shadow: 0 8px 40px rgba(247,148,29,.08), 0 10px 30px rgba(0,0,0,.03) !important;
    transition: transform .35s cubic-bezier(.22,1,.36,1), box-shadow .35s !important;
  }

  .business-section-{{ section.id }} .card:hover {
    transform: translateY(-8px) scale(1.01) !important;
    box-shadow: 0 24px 64px rgba(247,148,29,.18), 0 10px 30px rgba(0,0,0,.03) !important;
  }

  .business-section-{{ section.id }} .card:after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255,255,255,.3), transparent 40%);
    pointer-events: none;
    border-radius: 24px;
  }

  /* ── TIER STYLING (Mapped to VS Colors) ── */
  .business-section-{{ section.id }} .green { border-top: 5px solid #3EAD47 !important; }
  
  .business-section-{{ section.id }} .orange { 
    border-top: 5px solid #F7941D !important; 
    background-color: #FFFDF8; 
  }
  
  .business-section-{{ section.id }} .dark {
    border-top: 5px solid #E07810 !important;
    background: #111111;
    color: #FAFAF7;
    box-shadow: 0 20px 40px -10px rgba(17,17,17,0.4) !important;
  }

  .business-section-{{ section.id }} .badge {
    align-self: flex-start;
    padding: 6px 14px;
    border-radius: 999px;
    font-family: 'Baloo 2', sans-serif;
    font-size: 13px;
    font-weight: 800 !important;
    letter-spacing: 1px !important;
    text-transform: uppercase;
    margin-bottom: 24px;
    box-shadow: 0 6px 15px rgba(0,0,0,.06);
  }

  .business-section-{{ section.id }} .green .badge { background: #E8F5E9; color: #2E7D32; }
  .business-section-{{ section.id }} .orange .badge { background: #FFF3E0; color: #E07810; }
  .business-section-{{ section.id }} .dark .badge { background: rgba(247,148,29,0.15); color: #FDB44B; border: 1px solid rgba(247,148,29,0.3); }

  .business-section-{{ section.id }} .top-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }

  .business-section-{{ section.id }} .icon {
    width: 52px;
    height: 52px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    background: #ffffff;
    box-shadow: 0 10px 25px rgba(247,148,29,.15) !important;
  }

  .business-section-{{ section.id }} .dark .icon { background: rgba(255,255,255,0.08); box-shadow: none !important;}

  .business-section-{{ section.id }} .card h2 {
    margin: 0;
    font-family: 'Baloo 2', sans-serif;
    font-size: 1.35rem;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.3px;
    color: #111111;
  }
  .business-section-{{ section.id }} .dark h2 { color: #ffffff; }

  /* ── PRICING ── */
  .business-section-{{ section.id }} .amount-box {
    margin: 24px 0;
    padding: 20px;
    border-radius: 16px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.6);
    background: linear-gradient(180deg, #FAFAF7, #FFFFFF) !important;
    border: 1px solid rgba(247,148,29,.1);
  }

  .business-section-{{ section.id }} .dark .amount-box {
    background: rgba(255,255,255,0.03) !important;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: none;
  }

  .business-section-{{ section.id }} .label {
    font-family: 'Nunito', sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: #777777;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 4px;
  }
  .business-section-{{ section.id }} .dark .label { color: #a3a3a3; }

  .business-section-{{ section.id }} .amount {
    font-family: 'Baloo 2', sans-serif;
    font-size: 2.2rem;
    font-weight: 900;
    letter-spacing: -0.5px;
    line-height: 1;
  }

  .business-section-{{ section.id }} .green .amount { color: #3EAD47; text-shadow: 0 3px 14px rgba(62,173,71,.15); }
  .business-section-{{ section.id }} .orange .amount { color: #F7941D; text-shadow: 0 3px 14px rgba(247,148,29,.15); }
  .business-section-{{ section.id }} .dark .amount { color: #FDB44B; text-shadow: 0 3px 14px rgba(253,180,75,.2); }

  /* ── VALUE PROPOSITIONS ── */
  .business-section-{{ section.id }} .points {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 8px;
  }

  .business-section-{{ section.id }} .point {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.95rem;
    font-weight: 700 !important;
    line-height: 1.4;
    color: #444444;
  }
  .business-section-{{ section.id }} .dark .point { color: #e5e5e5; }

  .business-section-{{ section.id }} .tick {
    font-size: 13px;
    margin-top: 2px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .business-section-{{ section.id }} .green .tick { background: #E8F5E9; color: #3EAD47; }
  .business-section-{{ section.id }} .orange .tick { background: #FFF3E0; color: #F7941D; }
  .business-section-{{ section.id }} .dark .tick { background: rgba(253,180,75,0.2); color: #FDB44B; }

  /* ── BUTTON CONTAINER STYLES ── */
  .business-section-{{ section.id }} .book-btn {
    position: relative !important;
    display: flex !important;
    align-items: center;
    justify-content: center;
    width: 100% !important;
    max-width: 420px !important;
    margin: 22px auto 0 !important;
    padding: 16px 54px !important;
    border-radius: 999px !important;
    font-family: 'Baloo 2', sans-serif !important;
    font-size: 18px !important;
    font-weight: 900 !important;
    text-decoration: none;
    background: linear-gradient(135deg, #F7941D, #E07810) !important;
    color: #fff !important;
    box-shadow: 0 10px 32px rgba(247,148,29,.4), inset 0 2px 0 rgba(255,255,255,.2) !important;
    overflow: hidden !important; 
    letter-spacing: 0.5px !important;
    z-index: 10;
    text-align: center;
    transition: transform .25s cubic-bezier(.22,1,.36,1), box-shadow .25s !important;
  }

  .business-section-{{ section.id }} .book-btn:hover {
    transform: translateY(-3px) scale(1.02) !important;
    box-shadow: 0 18px 48px rgba(247,148,29,.55), inset 0 2px 0 rgba(255,255,255,.2) !important;
  }

  /* SVG Hand Base Properties */
  .business-section-{{ section.id }} .book-btn svg {
    position: absolute;
    width: 32px;
    height: 32px;
    top: 50%;
  }

  .business-section-{{ section.id }} .book-btn .hand-left {
    left: 12px;
    animation: handMoveL 1.2s ease-in-out infinite;
  }

  .business-section-{{ section.id }} .book-btn .hand-right {
    right: 12px;
    animation: handMoveR 1.2s ease-in-out infinite;
  }

  @keyframes handMoveL {
    0%, 100% { transform: translateY(-50%) scaleX(-1) translateX(0); }
    50% { transform: translateY(-50%) scaleX(-1) translateX(-5px); }
  }
  @keyframes handMoveR {
    0%, 100% { transform: translateY(-50%) scaleX(-1) translateX(0); }
    50% { transform: translateY(-50%) scaleX(-1) translateX(5px); }
  }

  /* ── RESPONSIVE DESIGN ── */
  @media(min-width: 768px) {
    .business-section-{{ section.id }} .grid { grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .business-section-{{ section.id }} .card { padding: 40px 32px; }
  }

  @media(max-width: 767px) {
    .business-section-{{ section.id }} { padding: 52px 14px !important; }
    .business-section-{{ section.id }} .grid { gap: 16px !important; }
    .business-section-{{ section.id }} .card {
      padding: 22px 18px !important;
      border-radius: 22px !important;
    }
    .business-section-{{ section.id }} .top-row {
      flex-direction: column !important;
      align-items: center !important;
      text-align: center !important;
      gap: 12px !important;
      margin-bottom: 14px !important;
    }
    .business-section-{{ section.id }} .icon {
      width: 48px !important;
      height: 48px !important;
      font-size: 22px !important;
      border-radius: 14px !important;
    }
    .business-section-{{ section.id }} .card h2 {
      font-size: 1.25rem !important;
      line-height: 1.1 !important;
      text-align: center;
    }
    .business-section-{{ section.id }} .amount-box {
      margin: 16px 0 !important;
      padding: 16px !important;
      border-radius: 14px !important;
    }
    .business-section-{{ section.id }} .amount { font-size: 2rem !important; }
    .business-section-{{ section.id }} .points { gap: 12px !important; }
    .business-section-{{ section.id }} .point {
      font-size: 14px !important;
      line-height: 1.4 !important;
      gap: 10px !important;
    }
    .business-section-{{ section.id }} .badge {
      font-size: 11px !important;
      padding: 6px 14px !important;
      margin-bottom: 16px !important;
    }
    .business-section-{{ section.id }} .heading h1 {
      font-size: 15vw !important;
      line-height: 1 !important;
      letter-spacing: -1px !important;
    }
    .business-section-{{ section.id }} .glow-line { width: 150px !important; height: 5px !important; }
    
    .business-section-{{ section.id }} .book-btn {
      width: 96% !important;
      max-width: 310px !important;
      padding: 14px 44px !important;
      font-size: 16px !important;
    }
    .business-section-{{ section.id }} .book-btn svg {
      width: 24px;
      height: 24px;
    }
    .business-section-{{ section.id }} .book-btn .hand-left { left: 14px; }
    .business-section-{{ section.id }} .book-btn .hand-right { right: 14px; }
  }
</style>

<section class="business-section-{{ section.id }}">
  <div class="container">
    
    <div class="heading">
      <h1>{{ section.settings.heading }}</h1>
      <div class="glow-line"></div>
    </div>

    <div class="grid">
      {% for block in section.blocks %}
        <div class="card {{ block.settings.theme_color }}" {{ block.shopify_attributes }}>
          <div class="badge">{{ block.settings.badge_text }}</div>
          
          <div class="top-row">
            <div class="icon">{{ block.settings.icon_emoji }}</div>
            <h2>{{ block.settings.card_title }}</h2>
          </div>
          
          <div class="amount-box">
            <div class="label">{{ block.settings.amount_label }}</div>
            <div class="amount">{{ block.settings.amount_value }}</div>
          </div>
          
          <div class="points">
            {% if block.settings.point_1 != blank %}
              <div class="point"><span class="tick">✓</span>{{ block.settings.point_1 }}</div>
            {% endif %}
            {% if block.settings.point_2 != blank %}
              <div class="point"><span class="tick">✓</span>{{ block.settings.point_2 }}</div>
            {% endif %}
            {% if block.settings.point_3 != blank %}
              <div class="point"><span class="tick">✓</span>{{ block.settings.point_3 }}</div>
            {% endif %}
            {% if block.settings.point_4 != blank %}
              <div class="point"><span class="tick">✓</span>{{ block.settings.point_4 }}</div>
            {% endif %}
            {% if block.settings.point_5 != blank %}
              <div class="point"><span class="tick">✓</span>{{ block.settings.point_5 }}</div>
            {% endif %}
          </div>
          
          <a href="{{ block.settings.button_link }}" class="book-btn">
