                  <div class="lx-totals-row">
                    <span class="lx-totals-row-label">Shipping</span>
                    <span class="lx-totals-row-value" {% if cart_total >= free_ship_threshold %}style="color:var(--lx-success);"{% endif %}>
                      {% if cart_total >= free_ship_threshold %}FREE{% else %}Calculated at checkout{% endif %}
                    </span>
                  </div>

                  <hr class="lx-totals-divider">

                  <div class="lx-totals-row lx-totals-row--grand totals">
                    <span class="lx-totals-row-label">Total Amount</span>
                    <span class="lx-totals-row-value totals__total-value">{{ cart.total_price | money }}</span>
                  </div>
                </div>

                {% if total_cart_savings > 0 %}
                <div class="lx-total-savings-banner">
                  <i class="ti ti-pig-money"></i>
                  <span class="lx-savings-text">You're saving {{ total_cart_savings | money }} on this order!</span>
                </div>
                {% endif %}

                <p class="lx-tax-note">
                  {%- if cart.duties_included and cart.taxes_included -%}
                    {%- if shop.shipping_policy.body == blank -%}{{ 'sections.cart.duties_and_taxes_included_shipping_at_checkout_without_policy' | t }}{%- else -%}{{ 'sections.cart.duties_and_taxes_included_shipping_at_checkout_with_policy_html' | t: link: shop.shipping_policy.url }}{%- endif -%}
                  {%- elsif cart.taxes_included -%}
                    {%- if shop.shipping_policy.body == blank -%}{{ 'sections.cart.taxes_included_shipping_at_checkout_without_policy' | t }}{%- else -%}{{ 'sections.cart.taxes_included_shipping_at_checkout_with_policy_html' | t: link: shop.shipping_policy.url }}{%- endif -%}
                  {%- else -%}
                    {%- if shop.shipping_policy.body == blank -%}{{ 'sections.cart.taxes_at_checkout_shipping_at_checkout_without_policy' | t }}{%- else -%}{{ 'sections.cart.taxes_at_checkout_shipping_at_checkout_with_policy_html' | t: link: shop.shipping_policy.url }}{%- endif -%}
                  {%- endif -%}
                </p>

                <div class="lx-checkout-wrap lx-desktop">
                  <button type="submit" id="checkout" class="lx-checkout-btn cart__checkout-button button" name="checkout" form="cart">
                    <i class="ti ti-lock" style="font-size:16px;"></i>
                    {{ 'sections.cart.checkout' | t }}
                    <i class="ti ti-arrow-right" style="font-size:16px;"></i>
                  </button>

                  {%- if additional_checkout_buttons -%}
                    <div class="cart__dynamic-checkout-buttons additional-checkout-buttons">
                      {{ content_for_additional_checkout_buttons }}
                    </div>
                  {%- endif -%}

                  <div class="lx-trust-badges">
                    <span class="lx-trust-item"><i class="ti ti-shield-check"></i> Secure Payment</span>
                    <span class="lx-trust-item"><i class="ti ti-truck-delivery"></i> Fast Shipping</span>
                    <span class="lx-trust-item"><i class="ti ti-refresh"></i> Easy Returns</span>
                  </div>
                </div>

                <div id="cart-errors"></div>
              </div>
            </div>
            
          </div>

          {%- if cart.item_count > 0 -%}
          <div class="lx-mobile" style="margin: 0 0 120px 0; padding: 0 16px;" id="lx-mobile-cross-sell-wrapper">
            <h4 class="lx-cross-sell-title" style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.3px;margin:20px 0 12px;color:#1A202C;">You May Also Like</h4>
            <div class="lx-cs-scroll" id="lx-cs-products-mobile" style="display:flex;gap:12px;overflow-x:auto;scrollbar-width:none;padding-bottom:4px;-webkit-overflow-scrolling:touch;">
              <div class="lx-cs-loading" style="display:flex;gap:12px;">
                <div class="lx-cs-placeholder"></div>
                <div class="lx-cs-placeholder"></div>
                <div class="lx-cs-placeholder"></div>
              </div>
            </div>
          </div>
          <script>
          (function() {
            var productId = {{ cart.items.first.product_id | json }};
            var url = window.Shopify.routes.root + 'recommendations/products.json?product_id=' + productId + '&limit=6&intent=related';
            fetch(url)
              .then(function(r){ return r.json(); })
              .then(function(data){
                var container = document.getElementById('lx-cs-products-mobile');
                if (!container) return;
                var products = data.products;
                if (!products || products.length === 0) {
                  var w = document.getElementById('lx-mobile-cross-sell-wrapper');
                  if(w) w.style.display='none';
                  return;
                }
                window._lxProducts = window._lxProducts || {};
                var html = '';
                products.forEach(function(p) {
                  window._lxProducts[p.id] = p;
                  var img = p.featured_image || '';
                  var price = (p.price/100).toLocaleString('en-IN',{style:'currency',currency:'INR',minimumFractionDigits:0});
                  var comparePrice = '';
                  if(p.compare_at_price && p.compare_at_price > p.price){
                    comparePrice = '<span style="font-size:10.5px;color:#9CA3AF;text-decoration:line-through;margin-left:4px;">'+(p.compare_at_price/100).toLocaleString('en-IN',{style:'currency',currency:'INR',minimumFractionDigits:0})+'</span>';
                  }
                  var hasOnlyDefault = p.variants && p.variants.length === 1 && p.variants[0].title === 'Default Title';
                  var variantId = p.variants && p.variants[0] ? p.variants[0].id : '';
                  html += '<div style="min-width:130px;max-width:130px;flex-shrink:0;">';
                  html += '<a href="'+p.url+'" style="display:block;height:160px;border-radius:10px;overflow:hidden;margin-bottom:8px;background:#F3F2EF;">';
                  if(img) html += '<img src="'+img+'" alt="'+p.title+'" style="width:100%;height:100%;object-fit:cover;display:block;" loading="lazy">';
                  html += '</a>';
                  html += '<a href="'+p.url+'" style="font-size:11.5px;font-weight:500;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#1A202C;text-decoration:none;margin-bottom:3px;">'+p.title+'</a>';
                  html += '<p style="font-size:12px;font-weight:700;margin:0 0 7px;color:#1A202C;">'+price+comparePrice+'</p>';
                  if(hasOnlyDefault){
                    html += '<button type="button" onclick="lxDirectAdd(this,\''+variantId+'\')" style="width:100%;background:#F3F2EF;border:1px solid #E5E7EB;color:#1A202C;border-radius:5px;padding:5px;font-size:11px;font-weight:600;cursor:pointer;font-family:inherit;">+ Quick Add</button>';
                  } else {
                    html += '<button type="button" onclick="lxOpenVariantModal(\''+p.id+'\')" style="width:100%;background:#F3F2EF;border:1px solid #E5E7EB;color:#1A202C;border-radius:5px;padding:5px;font-size:11px;font-weight:600;cursor:pointer;font-family:inherit;">+ Quick Add</button>';
                  }
                  html += '</div>';
                });
                container.innerHTML = html;
              })
              .catch(function(){
                var w = document.getElementById('lx-mobile-cross-sell-wrapper');
                if(w) w.style.display='none';
              });
          })();
          </script>
          {%- endif -%}

          <div class="lx-mobile-bar lx-mobile">
            <div class="lx-mob-total">
              <span class="lx-mob-total-label">Amount Payable</span>
              <span class="lx-mob-total-val">{{ cart.total_price | money }}</span>
              {%- if total_cart_savings > 0 -%}
                <span class="lx-mob-savings">Saving {{ total_cart_savings | money }}</span>
              {%- endif -%}
            </div>
            <button type="submit" class="lx-checkout-btn cart__checkout-button button" name="checkout" form="cart">
              Checkout <i class="ti ti-arrow-right"></i>
            </button>
          </div>

        {%- endif -%}
      </div>
    </div>
    
    <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
    <p class="visually-hidden" id="shopping-cart-line-item-status" aria-live="polite" aria-hidden="true" role="status">{{ 'accessibility.loading' | t }}</p>
  </form>

  <div id="main-cart-footer" data-id="fake-footer-id-do-not-remove" style="display:none;"></div>

</cart-items>

<script>
  window.lxVipConfig = {
    vipCode: {{ section.settings.vip_discount_code | default: 'PURCHASE1999' | json }},
    vipThreshold: {{ section.settings.vip_threshold | default: 2500 | times: 100 | json }}
  };
</script>
<script>
/* ═══════════════════════════════════════════════════
   LUXURY CART — COUPON SYSTEM
   ═══════════════════════════════════════════════════ */
(function () {
  const STORAGE_KEY = 'lx_coupon_code';
  const STORAGE_TIME = 'lx_coupon_time';

  // Check state on initial page load
  document.addEventListener('DOMContentLoaded', function () {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved) showAppliedState(saved);
  });

  // --- MANUAL COUPON SYSTEM ---
  function showAppliedState(code) {
    const banner  = document.getElementById('lx-applied-coupon');
    const picker  = document.getElementById('lx-coupon-picker');
    const codeLbl = document.getElementById('lx-applied-code-label');
    const timeLbl = document.getElementById('lx-applied-time');
    if (!banner || !picker) return;

    if (codeLbl) codeLbl.innerText = code;
    if (timeLbl) {
      const t = localStorage.getItem(STORAGE_TIME);
      timeLbl.innerText = t ? 'Applied at ' + t : '';
    }
    banner.classList.add('show');
    picker.style.display = 'none';
  }

  function hideAppliedState() {
    const banner = document.getElementById('lx-applied-coupon');
    const picker = document.getElementById('lx-coupon-picker');
    if (banner) banner.classList.remove('show');
    if (picker) picker.style.display = '';
  }

  function setMsg(text, type) {
    const el = document.getElementById('lx-coupon-msg');
    if (!el) return;
    const icons = { success: 'ti-circle-check', error: 'ti-alert-circle', warn: 'ti-lock' };
    const colors = { success: 'var(--lx-success)', error: 'var(--lx-danger)', warn: 'var(--lx-warn)' };
    el.style.color = colors[type] || 'var(--lx-text)';
    el.innerHTML = `<i class="ti ${icons[type] || ''}" style="font-size:14px;"></i> ${text}`;
  }

  window.lxApplyCoupon = async function (code) {
    if (!code || !code.trim()) { setMsg('Please enter a coupon code.', 'error'); return; }
    code = code.trim().toUpperCase();

    const vipCode = {{ section.settings.vip_discount_code | json }};
    const cartTotal = {{ cart.total_price | default: 0 }};
    const vipThreshold = {{ section.settings.vip_threshold | times: 100 | json }} || 999999999;
    
    let finalCode = code;
    
    // Stack with VIP if VIP threshold is met
    if (cartTotal >= vipThreshold && vipCode && vipCode.toUpperCase() !== code) {
       finalCode = vipCode + ',' + code;
    }

    setMsg('Applying ' + code + '…', null);

    try {
      const res = await fetch(window.Shopify.routes.root + 'cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ discount: finalCode })
      });

      if (res.ok) {
        const now = new Date();
        const timeStr = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        localStorage.setItem(STORAGE_KEY, code);
        localStorage.setItem(STORAGE_TIME, timeStr);

        setMsg('Coupon applied successfully!', 'success');

        const card = document.querySelector('.lx-summary-card');
        if (card) card.classList.add('lx-coupon-success-anim');

        setTimeout(() => {
          if (window.lxRefreshCartUI) {
            window.lxRefreshCartUI();
          } else {
            location.reload();
          }
        }, 500);
      } else {
        setMsg('Unable to apply coupon. Check the code and try again.', 'error');
      }
    } catch (e) {
      setMsg('Something went wrong. Please try again.', 'error');
    }
  };

  window.lxRemoveCoupon = async function () {
    const vipCode = {{ section.settings.vip_discount_code | json }};
    const cartTotal = {{ cart.total_price | default: 0 }};
    const vipThreshold = {{ section.settings.vip_threshold | times: 100 | json }} || 999999999;
    
    let finalCode = '';
    
    // Ensure VIP remains applied when user removes their manual coupon
    if (cartTotal >= vipThreshold && vipCode) {
       finalCode = vipCode; 
    }

    try {
      const res = await fetch(window.Shopify.routes.root + 'cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ discount: finalCode })
      });
      if (res.ok) {
        localStorage.removeItem(STORAGE_KEY);
        localStorage.removeItem(STORAGE_TIME);
        hideAppliedState();
        setTimeout(() => {
          if (window.lxRefreshCartUI) {
            window.lxRefreshCartUI();
          } else {
            location.reload();
          }
        }, 200);
      }
    } catch (e) {
      console.error('Remove coupon error:', e);
    }
  };

  document.addEventListener('DOMContentLoaded', function () {
    const input = document.getElementById('lx-code-input');
    if (input) {
      input.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          window.lxApplyCoupon(this.value);
        }
      });
    }
  });
})();
</script>

