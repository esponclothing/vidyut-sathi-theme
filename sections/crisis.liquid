<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;600;700;800;900&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet" />

<style>
  #vs-{{ section.id }} {
    --orange: {{ section.settings.color_orange }};
    --orange2: {{ section.settings.color_orange_dark }};
    --orange3: {{ section.settings.color_orange_light }};
    --green: {{ section.settings.color_green }};
    --green2: {{ section.settings.color_green_dark }};
    --green3: {{ section.settings.color_green_light }};
    --dark: {{ section.settings.color_dark }};
    --text: {{ section.settings.color_text }};
    --muted: {{ section.settings.color_muted }};
    --bg: {{ section.settings.color_bg }};
    --card-bg: {{ section.settings.color_card_bg }};
    --shadow: 0 8px 40px rgba(247,148,29,.15);
  }

  .vs-section-wrapper {
    width: 100%;
    background: var(--bg);
  }

  .vs-section {
    max-width: 1024px;
    width: 100%;
    margin: 0 auto;
    background: var(--bg);
    font-family: 'Nunito', sans-serif;
    position: relative;
    overflow: hidden;
    padding-bottom: 50px;
  }

  /* ambient glows */
  .vs-section::before {
    content: ''; position: absolute; top: -160px; right: -160px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(247,148,29,.10) 0%, transparent 65%);
    border-radius: 50%; pointer-events: none; z-index: 0;
  }
  .vs-section::after {
    content: ''; position: absolute; bottom: 300px; left: -160px;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(62,173,71,.08) 0%, transparent 65%);
    border-radius: 50%; pointer-events: none; z-index: 0;
  }

  /* TOP BAR */
  .vs-top-bar {
    width: 100%; height: 7px;
    background: linear-gradient(90deg, var(--green2) 0%, var(--green) 20%, var(--orange3) 50%, var(--orange) 80%, var(--green2) 100%);
  }

  /* HERO */
  .vs-hero {
    padding: 60px 40px 40px;
    position: relative; z-index: 2;
  }
  @media(min-width: 768px) { .vs-hero { padding: 60px 72px 40px; } }

  .vs-hero-label {
    display: inline-flex; align-items: center; gap: 10px;
    background: linear-gradient(135deg, rgba(247,148,29,.14), rgba(247,148,29,.04));
    border: 1.5px solid rgba(247,148,29,.35);
    border-radius: 50px; padding: 7px 22px; margin-bottom: 22px;
  }
  .vs-hero-label span {
    font-family: 'Baloo 2', sans-serif; font-size: 13px; font-weight: 800;
    letter-spacing: 3px; text-transform: uppercase; color: var(--orange2);
  }
  .vs-hero-label .dot {
    width: 9px; height: 9px; background: var(--orange); border-radius: 50%;
    box-shadow: 0 0 8px rgba(247,148,29,.7); animation: vsPulse 2s ease-in-out infinite;
  }
  @keyframes vsPulse {
    0%,100% { transform: scale(1); box-shadow: 0 0 8px rgba(247,148,29,.7); }
    50% { transform: scale(1.5); box-shadow: 0 0 16px rgba(247,148,29,.4); }
  }

  .vs-hero h1 {
    font-family: 'Baloo 2', sans-serif; font-weight: 900;
    line-height: 1.08; color: var(--dark); letter-spacing: -1.5px;
    font-size: 48px; margin: 0;
  }
  @media(min-width: 768px) { .vs-hero h1 { font-size: 68px; } }

  .vs-hero h1 .accent { color: var(--orange); position: relative; display: inline-block; }
  .vs-hero h1 .accent::after {
    content: ''; position: absolute; left: 0; bottom: -4px;
    width: 100%; height: 4px; border-radius: 2px; opacity: .5;
    background: linear-gradient(90deg, var(--orange), var(--orange3));
  }
  .vs-hero-divider {
    margin-top: 28px; width: 90px; height: 5px; border-radius: 3px;
    background: linear-gradient(90deg, var(--orange), var(--green));
  }

  /* TOWER SVG */
  .vs-hero-illustration {
    position: absolute; top: 30px; right: 20px;
    width: 120px; height: 180px; opacity: .13; z-index: 1; color: var(--orange);
  }
  @media(min-width: 768px) {
    .vs-hero-illustration { right: 55px; width: 200px; height: 260px; }
  }
  .vs-hero-illustration svg { width: 100%; height: 100%; object-fit: contain; }

  /* STATS GRID */
  .vs-stats-grid {
    display: grid; gap: 22px; padding: 0 20px;
    position: relative; z-index: 2; margin-top: 10px;
    grid-template-columns: 1fr;
  }
  @media(min-width: 768px) {
    .vs-stats-grid { grid-template-columns: repeat(3, 1fr); padding: 0 72px; }
  }

  .vs-stat-card {
    background: var(--card-bg); border-radius: 26px; padding: 42px 30px 38px;
    box-shadow: var(--shadow); border: 1.5px solid rgba(247,148,29,.08);
    position: relative; overflow: hidden;
    transition: transform .3s cubic-bezier(.22,1,.36,1), box-shadow .3s;
  }
  .vs-stat-card:hover {
    transform: translateY(-8px) scale(1.01); box-shadow: 0 24px 64px rgba(247,148,29,.22);
  }

  .vs-card-glow {
    position: absolute; top: -40px; right: -40px; width: 160px; height: 160px;
    border-radius: 50%; pointer-events: none; opacity: .35;
  }
  
  .vs-stat-card.style-orange .vs-card-glow { background: radial-gradient(circle, rgba(247,148,29,.4), transparent 70%); }
  .vs-stat-card.style-green .vs-card-glow { background: radial-gradient(circle, rgba(62,173,71,.4), transparent 70%); }

  .vs-stat-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 5px; }
  .vs-stat-card::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 5px; border-radius: 0 0 26px 26px; }
  
  .vs-stat-card.style-orange::before, .vs-stat-card.style-orange::after { background: linear-gradient(90deg, var(--orange), var(--orange3)); }
  .vs-stat-card.style-green::before, .vs-stat-card.style-green::after { background: linear-gradient(90deg, var(--green), var(--green3)); }

  .vs-stat-icon-wrap {
    width: 70px; height: 70px; border-radius: 18px; display: flex; align-items: center; justify-content: center;
    margin-bottom: 26px; position: relative; z-index: 1; color: var(--orange);
  }
  .vs-stat-card.style-orange .vs-stat-icon-wrap { background: linear-gradient(135deg, #FFF3E0, #FFE0B2); box-shadow: 0 6px 20px rgba(247,148,29,.2); color: var(--orange); }
  .vs-stat-card.style-green .vs-stat-icon-wrap { background: linear-gradient(135deg, #E8F5E9, #C8E6C9); box-shadow: 0 6px 20px rgba(62,173,71,.2); color: var(--green); }
  .vs-stat-icon-wrap svg { width: 34px; height: 34px; }

  .vs-stat-value {
    font-family: 'Baloo 2', sans-serif; font-size: 54px; font-weight: 900; line-height: 1;
    margin-bottom: 14px; position: relative; z-index: 1; letter-spacing: -1px;
  }
  .vs-stat-card.style-orange .vs-stat-value { color: var(--orange); }
  .vs-stat-card.style-green .vs-stat-value { color: var(--green); }

  .vs-stat-divider {
    width: 44px; height: 3px; border-radius: 2px; margin-bottom: 16px; position: relative; z-index: 1;
  }
  .vs-stat-card.style-orange .vs-stat-divider { background: linear-gradient(90deg, var(--orange), transparent); }
  .vs-stat-card.style-green .vs-stat-divider { background: linear-gradient(90deg, var(--green), transparent); }

  .vs-stat-desc { font-size: 22px; font-weight: 800; color: var(--dark); line-height: 1.5; position: relative; z-index: 1; }

  /* NEED BANNER */
  .vs-need-banner {
    margin: 32px 20px 0; background: linear-gradient(135deg, #FFFBF3, #FFF3E0, #FFFBF3);
    border: 2px solid rgba(247,148,29,.25); border-radius: 22px; padding: 20px 24px;
    display: flex; align-items: center; gap: 20px; flex-direction: column; text-align: center;
    position: relative; z-index: 2; box-shadow: 0 4px 24px rgba(247,148,29,.12), inset 0 1px 0 rgba(255,255,255,.8);
  }
  @media(min-width: 768px) {
    .vs-need-banner { flex-direction: row; text-align: left; padding: 30px 38px; margin: 32px 72px 0; }
  }

  .vs-need-icon {
    width: 64px; height: 64px; flex-shrink: 0; background: white; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 6px 20px rgba(247,148,29,.25); border: 2px solid rgba(247,148,29,.15);
  }
  .vs-need-divider {
    display: none; width: 3px; height: 56px; background: linear-gradient(180deg, var(--orange), var(--green));
    border-radius: 2px; flex-shrink: 0;
  }
  @media(min-width: 768px) { .vs-need-divider { display: block; } }

  .vs-need-label { font-family: 'Baloo 2', sans-serif; font-size: 24px; font-weight: 900; color: var(--orange); white-space: nowrap; }
  .vs-need-text { font-size: 17px; font-weight: 700; color: var(--text); line-height: 1.6; margin: 0;}

  /* SECTION BREAK */
  .vs-section-break {
    margin: 56px 20px 36px; display: flex; align-items: center; gap: 15px; position: relative; z-index: 2;
  }
  @media(min-width: 768px) { .vs-section-break { margin: 56px 72px 36px; gap: 20px; } }

  .vs-break-line { flex: 1; height: 1px; background: linear-gradient(90deg, rgba(247,148,29,.35), transparent); }
  .vs-break-line.rev { background: linear-gradient(270deg, rgba(247,148,29,.35), transparent); }
  .vs-break-text {
    font-family: 'Baloo 2', sans-serif; font-size: 11px; font-weight: 800; letter-spacing: 2px;
    text-transform: uppercase; color: var(--orange2); white-space: nowrap;
    background: linear-gradient(135deg, rgba(247,148,29,.1), transparent);
    padding: 6px 14px; border-radius: 50px; border: 1px solid rgba(247,148,29,.2);
  }
  @media(min-width: 768px) { .vs-break-text { font-size: 13px; padding: 6px 18px; letter-spacing: 3px; } }

  /* SOLUTION HEADER */
  .vs-solution-wrap { padding: 0 20px; position: relative; z-index: 2; }
  @media(min-width: 768px) { .vs-solution-wrap { padding: 0 72px; } }

  .vs-solution-header { text-align: center; margin-bottom: 44px; position: relative; }
  .vs-solution-header::before { content: '✦'; position: absolute; left: 10%; top: 0; font-size: 22px; color: var(--orange); opacity: .25; }
  .vs-solution-header::after { content: '✦'; position: absolute; right: 10%; top: 10px; font-size: 16px; color: var(--green); opacity: .3; }
  
  @media(min-width: 768px) {
    .vs-solution-header::before { left: 80px; top: 10px; }
    .vs-solution-header::after { right: 80px; }
  }

  .vs-solution-header h2 {
    font-family: 'Baloo 2', sans-serif; font-size: 38px; font-weight: 900;
    color: var(--dark); line-height: 1.15; letter-spacing: -.5px; margin: 0;
  }
  @media(min-width: 768px) { .vs-solution-header h2 { font-size: 50px; } }
  .vs-solution-header h2 span { color: var(--orange); }
  
  .vs-solution-header p {
    margin: 12px 0 0 0; font-size: 18px; font-weight: 700; color: var(--muted); letter-spacing: .2px;
  }
  @media(min-width: 768px) { .vs-solution-header p { font-size: 22px; } }

  .vs-subtitle-line {
    display: inline-block; margin-top: 16px; width: 80px; height: 4px;
    background: linear-gradient(90deg, var(--orange), var(--green)); border-radius: 2px;
  }

  /* CTA CARD */
  .vs-bottom-cta {
    margin: 0 20px 0; background: linear-gradient(135deg, #FFFDF8, #FFF6E8, #FFFDF8);
    border-radius: 28px; padding: 35px 25px; display: flex; flex-direction: column;
    align-items: center; justify-content: space-between; gap: 30px; text-align: center;
    border: 2px solid rgba(247,148,29,.18); box-shadow: 0 8px 40px rgba(247,148,29,.12), inset 0 1px 0 rgba(255,255,255,.9);
    position: relative; z-index: 2; overflow: hidden;
  }
  @media(min-width: 768px) {
    .vs-bottom-cta { margin: 0 72px 0; flex-direction: row; padding: 44px 52px; gap: 36px; text-align: left; }
  }

  .vs-bottom-cta::before {
    content: ''; position: absolute; top: -60px; left: -60px; width: 240px; height: 240px;
    background: radial-gradient(circle, rgba(247,148,29,.1), transparent 65%); pointer-events: none;
  }
  .vs-bottom-cta::after {
    content: ''; position: absolute; bottom: -50px; right: -50px; width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(62,173,71,.08), transparent 65%); pointer-events: none;
  }

  .vs-cta-left { position: relative; z-index: 1; }
  .vs-cta-left h3 {
    font-family: 'Baloo 2', sans-serif; font-size: 26px; font-weight: 900; color: var(--dark); line-height: 1.2; margin: 0;
  }
  @media(min-width: 768px) { .vs-cta-left h3 { font-size: 30px; } }
  .vs-cta-left h3 span { color: var(--orange); }
  .vs-cta-left p { margin: 10px 0 0 0; font-size: 16px; font-weight: 700; color: var(--muted); }

  .vs-cta-proof {
    display: flex; align-items: center; justify-content: center; gap: 10px; margin-top: 14px;
  }
  @media(min-width: 768px) { .vs-cta-proof { justify-content: flex-start; } }

  .vs-cta-avatars { display: flex; }
  .vs-cta-avatars span {
    width: 32px; height: 32px; border-radius: 50%; border: 2px solid white;
    display: inline-flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 800;
    margin-left: -8px; color: white;
  }
  .vs-cta-avatars span:first-child { margin-left: 0; background: #F7941D; }
  .vs-cta-avatars span:nth-child(2) { background: #3EAD47; }
  .vs-cta-avatars span:nth-child(3) { background: #E07810; }
  
  .vs-cta-proof-text { font-size: 13px; font-weight: 700; color: var(--muted); }
  .vs-cta-proof-text strong { color: var(--orange); }

  .vs-cta-right { position: relative; z-index: 1; flex-shrink: 0; text-align: center; }
  .vs-cta-btn {
    display: inline-flex; align-items: center; gap: 12px; background: linear-gradient(135deg, var(--orange), var(--orange2));
    color: white; font-family: 'Baloo 2', sans-serif; font-size: 19px; font-weight: 900;
    padding: 18px 44px; border-radius: 50px; text-decoration: none;
    box-shadow: 0 10px 32px rgba(247,148,29,.4), 0 2px 0 rgba(0,0,0,.1) inset;
    letter-spacing: .3px; transition: transform .25s cubic-bezier(.22,1,.36,1), box-shadow .25s; white-space: nowrap;
  }
  .vs-cta-btn:hover {
    transform: translateY(-3px) scale(1.02); box-shadow: 0 18px 48px rgba(247,148,29,.55); color: white;
  }
  .vs-cta-btn svg { width: 22px; height: 22px; }
  .vs-cta-note {
    margin-top: 10px; font-size: 12px; font-weight: 700; color: var(--green2);
    display: flex; align-items: center; justify-content: center; gap: 5px;
  }
  .vs-cta-note::before { content: '✓'; font-weight: 900; }

  .vs-bottom-bar {
    margin-top: 52px; width: 100%; height: 7px;
    background: linear-gradient(90deg, var(--green2) 0%, var(--green) 20%, var(--orange3) 50%, var(--orange) 80%, var(--green2) 100%);
  }
</style>

<div class="vs-section-wrapper" id="vs-{{ section.id }}">
  <section class="vs-section">

    <div class="vs-top-bar"></div>

    <div class="vs-hero-illustration" aria-hidden="true">
      {% if section.settings.hero_bg_svg != blank %}
        {{ section.settings.hero_bg_svg }}
      {% endif %}
    </div>

    <div class="vs-hero">
      <div class="vs-hero-label">
        <div class="dot"></div>
        <span>{{ section.settings.hero_label }}</span>
      </div>
      <h1>
        {{ section.settings.hero_heading }}
        <span class="accent">{{ section.settings.hero_heading_highlight }}</span>
        {{ section.settings.hero_heading_suffix }}
      </h1>
      <div class="vs-hero-divider"></div>
    </div>

    <div class="vs-stats-grid">
      {% for block in section.blocks %}
        <div class="vs-stat-card style-{{ block.settings.card_style }}" {{ block.shopify_attributes }}>
          <div class="vs-card-glow"></div>
          <div class="vs-stat-icon-wrap">
            {% if block.settings.icon_svg != blank %}
              {{ block.settings.icon_svg }}
            {% else %}
              <svg viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="17" cy="17" r="8" fill="currentColor"/></svg>
            {% endif %}
          </div>
          <div class="vs-stat-value">{{ block.settings.stat_value }}</div>
          <div class="vs-stat-divider"></div>
          <div class="vs-stat-desc">{{ block.settings.stat_desc }}</div>
        </div>
      {% endfor %}
    </div>

    <div class="vs-need-banner">
      <div class="vs-need-icon">
        <svg width="30" height="30" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="15" cy="11" r="7.5" stroke="{{ section.settings.color_orange }}" stroke-width="2.2" fill="none"/>
          <path d="M12 11c0-1.66 1.34-3 3-3" stroke="{{ section.settings.color_orange }}" stroke-width="2" stroke-linecap="round"/>
          <line x1="15" y1="19" x2="15" y2="23" stroke="{{ section.settings.color_orange }}" stroke-width="2.2" stroke-linecap="round"/>
          <line x1="11" y1="26" x2="19" y2="26" stroke="{{ section.settings.color_orange }}" stroke-width="2.2" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="vs-need-divider"></div>
      <div class="vs-need-label">{{ section.settings.banner_label }}</div>
      <div class="vs-need-text">{{ section.settings.banner_text }}</div>
    </div>

    <div class="vs-section-break">
      <div class="vs-break-line"></div>
      <div class="vs-break-text">{{ section.settings.break_text }}</div>
      <div class="vs-break-line rev"></div>
    </div>

    <div class="vs-solution-wrap">
      <div class="vs-solution-header">
        <h2>{{ section.settings.solution_heading }}<span>{{ section.settings.solution_highlight }}</span></h2>
        <p>{{ section.settings.solution_subtitle }}</p>
        <div class="vs-subtitle-line"></div>
      </div>
    </div>

    <div class="vs-bottom-cta">
      <div class="vs-cta-left">
        <h3>{{ section.settings.cta_heading }}<span>{{ section.settings.cta_highlight }}</span>{{ section.settings.cta_suffix }}</h3>
        <p>{{ section.settings.cta_subtitle }}</p>
        <div class="vs-cta-proof">
          <div class="vs-cta-avatars">
            <span>{{ section.settings.avatar_1 }}</span>
            <span>{{ section.settings.avatar_2 }}</span>
            <span>{{ section.settings.avatar_3 }}</span>
          </div>
          <div class="vs-cta-proof-text"><strong>{{ section.settings.cta_proof_highlight }}</strong> {{ section.settings.cta_proof_text }}</div>
        </div>
      </div>
      <div class="vs-cta-right">
        <a href="{{ section.settings.btn_link | default: '#' }}" class="vs-cta-btn">
          <svg viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
            <polygon points="11,3 7,12 11,12 10,19 15,10 11,10" fill="white"/>
          </svg>
          {{ section.settings.btn_text }}
        </a>
        <div class="vs-cta-note">{{ section.settings.btn_note }}</div>
      </div>
    </div>

    <div class="vs-bottom-bar"></div>

  </section>
</div>