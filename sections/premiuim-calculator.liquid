{%- comment -%}

  Vidhyut Saathi Premium Calculator - Strict Mobile-First & Desktop Optimized

{%- endcomment -%}



{%- style -%}

  {{ section.settings.heading_font | font_face: font_display: 'swap' }}

  {{ section.settings.body_font | font_face: font_display: 'swap' }}



  .premium-calculator-{{ section.id }} {

    --green: {{ section.settings.color_green }};

    --green2: {{ section.settings.color_green2 }};

    --orange: {{ section.settings.color_orange }};

    --text: {{ section.settings.color_text }};

    --muted: {{ section.settings.color_muted }};

    --gradient: linear-gradient(135deg, var(--green), var(--orange));

    --heading-font: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};

    --body-font: {{ section.settings.body_font.family }}, {{ section.settings.body_font.fallback_families }};

   

    font-family: var(--body-font);

    background:

      radial-gradient(circle at top right, rgba(20,140,58,.08), transparent 30%),

      radial-gradient(circle at bottom left, rgba(245,130,32,.08), transparent 30%), #fff;

    min-height: 100vh;

    display: flex;

    align-items: center;

    justify-content: center;

    padding: 40px 20px; /* Original mobile padding */

    position: relative;

    overflow: hidden;

    animation: bgFloat-{{ section.id }} 10s ease-in-out infinite alternate;

  }



  .premium-calculator-{{ section.id }} * {

    margin: 0;

    padding: 0;

    box-sizing: border-box;

  }



  .premium-calculator-{{ section.id }} .bg-grid {

    position: absolute;

    inset: 0;

    background-image: linear-gradient(rgba(20,140,58,.03) 1px, transparent 1px), linear-gradient(90deg, rgba(20,140,58,.03) 1px, transparent 1px);

    background-size: 40px 40px;

    pointer-events: none;

  }



  .premium-calculator-{{ section.id }} .blur {

    position: absolute;

    border-radius: 50%;

    filter: blur(90px);

    animation: floatBlur-{{ section.id }} 8s ease-in-out infinite alternate;

  }

  .premium-calculator-{{ section.id }} .blur1 { width: 300px; height: 300px; background: rgba(20,140,58,.08); top: -100px; right: -100px; }

  .premium-calculator-{{ section.id }} .blur2 { width: 260px; height: 260px; background: rgba(245,130,32,.08); bottom: -100px; left: -100px; }

 

  /* BASE WRAPPER (Mobile / Tablet) */

  .premium-calculator-{{ section.id }} .wrapper { width: 100%; max-width: 520px; position: relative; z-index: 10; margin: 0 auto; }

 

  .premium-calculator-{{ section.id }} .calc-card {

    animation: floatCard-{{ section.id }} 4s ease-in-out infinite alternate;

    background: linear-gradient(135deg, rgba(255,255,255,.95), rgba(255,255,255,.82));

    border: 1px solid rgba(20,140,58,.12);

    border-radius: 30px;

    padding: 34px 26px; /* Original mobile padding */

    backdrop-filter: blur(18px);

    box-shadow: 0 20px 60px rgba(0,0,0,.05), 0 0 35px rgba(245,130,32,.06);

    animation: cardEnter-{{ section.id }} .8s ease;

  }



  .premium-calculator-{{ section.id }} .tag-wrapper { text-align: center; }

  .premium-calculator-{{ section.id }} .section-tag {

    display: inline-flex; align-items: center; gap: 10px; padding: 10px 18px; border-radius: 999px;

    background: rgba(20,140,58,.06); border: 1px solid rgba(20,140,58,.10);

    color: var(--green); font-size: .72rem; font-weight: 700; letter-spacing: .12em;

    text-transform: uppercase; margin-bottom: 22px;

  }

  .premium-calculator-{{ section.id }} .tag-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--orange); animation: pulse-{{ section.id }} 1.4s infinite; }

 

  .premium-calculator-{{ section.id }} .section-title {

    font-family: var(--heading-font); font-size: 3rem; line-height: 1.1; font-weight: 900; margin-bottom: 18px; color: var(--text); text-align: center;

  }

  .premium-calculator-{{ section.id }} .section-title span { background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

  .premium-calculator-{{ section.id }} .section-sub { text-align: center; color: var(--muted); font-size: 1rem; line-height: 1.8; margin: 0 auto 34px; }

 

  .premium-calculator-{{ section.id }} .calc-label { font-size: .8rem; color: var(--muted); margin-bottom: 10px; }

  .premium-calculator-{{ section.id }} .calc-val-display { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }

  .premium-calculator-{{ section.id }} .calc-current {

    font-family: var(--heading-font); font-size: 3rem; font-weight: 900; background: linear-gradient(135deg, var(--green), var(--green2));

    -webkit-background-clip: text; -webkit-text-fill-color: transparent; text-shadow: 0 0 20px rgba(20,140,58,.15);

  }

 

  .premium-calculator-{{ section.id }} .calc-slider {

    -webkit-appearance: none; width: 100%; height: 8px; border-radius: 999px;

    background: linear-gradient(90deg, var(--orange), #ffc642, var(--green2));

    background-size: 200% 200%; animation: sliderMove-{{ section.id }} 4s linear infinite; cursor: pointer;

  }

  .premium-calculator-{{ section.id }} .calc-slider::-webkit-slider-thumb {

    -webkit-appearance: none; width: 28px; height: 28px; background: #fff; border-radius: 50%;

    border: 4px solid var(--green); box-shadow: 0 0 0 8px rgba(20,140,58,.12), 0 5px 15px rgba(0,0,0,.08);

  }

 

  /* BASE 2-COLUMN GRID (Original Mobile) */

  .premium-calculator-{{ section.id }} .calc-results { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 28px; }

  .premium-calculator-{{ section.id }} .calc-result-card {

    background: rgba(255,255,255,.92); border: 1px solid rgba(20,140,58,.10); border-radius: 18px;

    padding: 22px 16px; text-align: center; transition: .35s ease; position: relative; box-shadow: 0 10px 25px rgba(0,0,0,.03);

  }

  .premium-calculator-{{ section.id }} .calc-result-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: var(--gradient); border-radius: 18px 18px 0 0; }

  .premium-calculator-{{ section.id }} .calc-result-card:hover { transform: translateY(-6px) scale(1.02); box-shadow: 0 18px 35px rgba(20,140,58,.08); }

 

  .premium-calculator-{{ section.id }} .calc-result-val {

    font-family: var(--heading-font); font-size: 2rem; font-weight: 900; background: var(--gradient);

    -webkit-background-clip: text; -webkit-text-fill-color: transparent; animation: softGlow-{{ section.id }} 2s infinite;

  }

  .premium-calculator-{{ section.id }} .calc-result-label { font-size: .78rem; color: var(--muted); margin-top: 6px; }

 

  .premium-calculator-{{ section.id }} .calc-disclaimer {

    margin-top: 24px; background: rgba(20,140,58,.04); border: 1px solid rgba(20,140,58,.08); border-radius: 14px;

    padding: 14px 16px; text-align: center; color: var(--muted); font-size: .75rem; line-height: 1.7;

  }

 

  /* BASE 2-COLUMN TRUST STRIP (Original Mobile) */

  .premium-calculator-{{ section.id }} .trust-strip { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 22px; }

  .premium-calculator-{{ section.id }} .trust-item {

    position: relative; overflow: hidden; background: rgba(255,255,255,.88);

    border-radius: 22px; padding: 18px 12px; text-align: center; transition: .35s ease; z-index: 1;

  }

  .premium-calculator-{{ section.id }} .trust-item::before {

    content: ''; position: absolute; inset: -4px; border-radius: 26px;

    background: linear-gradient(90deg, var(--green), #22c55e, var(--orange), #ffd44d, var(--green));

    background-size: 300% 300%; animation: premiumOutline-{{ section.id }} 4s linear infinite; z-index: -2;

  }

  .premium-calculator-{{ section.id }} .trust-item::after {

    content: ''; position: absolute; inset: 4px;

    background: linear-gradient(135deg, rgba(255,255,255,.96), rgba(255,255,255,.90)); border-radius: 18px; z-index: -1;

  }

  .premium-calculator-{{ section.id }} .trust-item:hover {

    transform: translateY(-8px) scale(1.03); box-shadow: 0 15px 40px rgba(20,140,58,.15), 0 0 30px rgba(245,130,32,.12);

  }

 

  .premium-calculator-{{ section.id }} .electric-particle {

    position: absolute; width: 10px; height: 10px; border-radius: 50%;

    background: rgba(245,130,32,.25); animation: particleMove-{{ section.id }} 10s linear infinite; filter: blur(1px);

  }

  .premium-calculator-{{ section.id }} .heading-line { display: inline-block; white-space: nowrap; }



  /* STRICT MOBILE TWEAKS (Matches original exactly) */

  @media(max-width: 520px) {

    .premium-calculator-{{ section.id }} .section-title { font-size: 2rem !important; line-height: 1.15 !important; }

    .premium-calculator-{{ section.id }} .heading-line { font-size: .95em; }

    .premium-calculator-{{ section.id }} .calc-current { font-size: 2.4rem; }

    .premium-calculator-{{ section.id }} .calc-results { grid-template-columns: 1fr 1fr; gap: 12px; }

    .premium-calculator-{{ section.id }} .calc-result-card { padding: 18px 12px; }

    .premium-calculator-{{ section.id }} .calc-result-val { font-size: 1.5rem; }

  }



  /* DESKTOP ENHANCEMENTS */

  @media(min-width: 768px) {

    .premium-calculator-{{ section.id }} { padding: 60px 20px; }

    .premium-calculator-{{ section.id }} .wrapper { max-width: 900px; }

    .premium-calculator-{{ section.id }} .calc-card { padding: 50px 60px; border-radius: 36px; }

    .premium-calculator-{{ section.id }} .section-title { font-size: 3.5rem; line-height: 1.15; }

    .premium-calculator-{{ section.id }} .section-sub { font-size: 1.1rem; margin-bottom: 40px; }

    .premium-calculator-{{ section.id }} .calc-current { font-size: 3.5rem; }

    .premium-calculator-{{ section.id }} .calc-results { grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 36px; }

    .premium-calculator-{{ section.id }} .calc-result-card { padding: 26px 16px; }

    .premium-calculator-{{ section.id }} .calc-result-val { font-size: 2.2rem; }

    .premium-calculator-{{ section.id }} .trust-strip { grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 26px; }

    .premium-calculator-{{ section.id }} .trust-item { padding: 20px 12px; }

    .premium-calculator-{{ section.id }} .blur1 { width: 350px; height: 350px; top: -50px; right: -50px; }

    .premium-calculator-{{ section.id }} .blur2 { width: 300px; height: 300px; bottom: -50px; left: -50px; }

  }



  /* Animations */

  @keyframes pulse-{{ section.id }} { 50% { transform: scale(1.4); } }

  @keyframes sliderMove-{{ section.id }} { 0% { background-position: left center; } 100% { background-position: right center; } }

  @keyframes floatBlur-{{ section.id }} { 100% { transform: translateY(20px) translateX(10px); } }

  @keyframes bgFloat-{{ section.id }} { 100% { background-position: right bottom; } }

  @keyframes softGlow-{{ section.id }} { 50% { filter: drop-shadow(0 0 8px rgba(245,130,32,.25)); } }

  @keyframes cardEnter-{{ section.id }} { from { opacity: 0; transform: translateY(25px); } to { opacity: 1; transform: translateY(0); } }

  @keyframes floatCard-{{ section.id }} { 0% { transform: translateY(0); } 100% { transform: translateY(-8px); } }

  @keyframes particleMove-{{ section.id }} { 0% { transform: translateY(100vh) translateX(0); } 100% { transform: translateY(-100vh) translateX(80px); } }

  @keyframes premiumOutline-{{ section.id }} { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }



{%- endstyle -%}



<div class="premium-calculator-{{ section.id }}"

     id="calc-data-{{ section.id }}"

     data-price="{{ section.settings.calc_price }}"

     data-pct-base="{{ section.settings.pct_base | divided_by: 100.0 }}"

     data-pct-mid="{{ section.settings.pct_mid | divided_by: 100.0 }}"

     data-pct-high="{{ section.settings.pct_high | divided_by: 100.0 }}">

 

  <div class="electric-particle" style="left:15%; animation-duration:7s;"></div>

  <div class="electric-particle" style="left:40%; animation-duration:11s;"></div>

  <div class="electric-particle" style="left:75%; animation-duration:9s;"></div>

  <div class="electric-particle" style="left:90%; animation-duration:13s;"></div>



  <div class="bg-grid"></div>

  <div class="blur blur1"></div>

  <div class="blur blur2"></div>



  <div class="wrapper">

    <div class="calc-card">

     

      <div class="tag-wrapper">

        <div class="section-tag"><div class="tag-dot"></div>{{ section.settings.tag_text }}</div>

      </div>

     

      <h2 class="section-title">

        {{ section.settings.heading_text }} <br>

        <span class="heading-line">{{ section.settings.heading_highlight }}</span>

      </h2>

     

      <p class="section-sub">{{ section.settings.subheading_text }}</p>

     

      <div class="calc-label">{{ section.settings.slider_label }}</div>

      <div class="calc-val-display">

        <div class="calc-current">₹<span id="billDisplay-{{ section.id }}">{{ section.settings.slider_default }}</span></div>

        <div style="font-size:.75rem; color:var(--muted);">per month</div>

      </div>

     

      <input type="range" class="calc-slider" id="billSlider-{{ section.id }}"

             min="{{ section.settings.slider_min }}"

             max="{{ section.settings.slider_max }}"

             step="{{ section.settings.slider_step }}"

             value="{{ section.settings.slider_default }}">

             

      <div style="display:flex; justify-content:space-between; font-size:.72rem; color:var(--muted); margin-top:10px; margin-bottom:22px;">

        <span id="minLabel-{{ section.id }}">₹{{ section.settings.slider_min }}</span>

        <span id="maxLabel-{{ section.id }}">₹{{ section.settings.slider_max }}</span>

      </div>



      <div class="calc-results">

        <div class="calc-result-card">

          <div class="calc-result-val" id="monthlySaving-{{ section.id }}">₹0</div>

          <div class="calc-result-label">{{ section.settings.label_monthly }}</div>

        </div>

        <div class="calc-result-card">

          <div class="calc-result-val" id="yearlySaving-{{ section.id }}">₹0</div>

          <div class="calc-result-label">{{ section.settings.label_yearly }}</div>

        </div>

        <div class="calc-result-card">

          <div class="calc-result-val" id="newBill-{{ section.id }}">₹0</div>

          <div class="calc-result-label">{{ section.settings.label_newbill }}</div>

        </div>

        <div class="calc-result-card">

          <div class="calc-result-val" id="roiMonths-{{ section.id }}">0 Mo</div>

          <div class="calc-result-label">{{ section.settings.label_roi }}</div>

        </div>

      </div>



      <p class="calc-disclaimer">{{ section.settings.disclaimer_text }}</p>



      <div class="trust-strip">

        {%- for block in section.blocks -%}

          <div class="trust-item">{{ block.settings.icon }}<div>{{ block.settings.text }}</div></div>

        {%- endfor -%}

      </div>



    </div>

  </div>

</div>



<script>

  document.addEventListener('DOMContentLoaded', function() {

    const sectionId = '{{ section.id }}';

    const container = document.getElementById(`calc-data-${sectionId}`);

   

    if (!container) return;

   

    const slider = document.getElementById(`billSlider-${sectionId}`);

    const display = document.getElementById(`billDisplay-${sectionId}`);

    const mSaving = document.getElementById(`monthlySaving-${sectionId}`);

    const ySaving = document.getElementById(`yearlySaving-${sectionId}`);

    const nBill = document.getElementById(`newBill-${sectionId}`);

    const roi = document.getElementById(`roiMonths-${sectionId}`);

   

    const minLabel = document.getElementById(`minLabel-${sectionId}`);

    const maxLabel = document.getElementById(`maxLabel-${sectionId}`);

   

    // Format min and max labels properly using Indian currency numbering

    if (minLabel) minLabel.textContent = '₹' + parseInt(slider.min).toLocaleString('en-IN');

    if (maxLabel) maxLabel.textContent = '₹' + parseInt(slider.max).toLocaleString('en-IN');

   

    const PRICE = parseInt(container.dataset.price) || 3498;

    const pctBase = parseFloat(container.dataset.pctBase) || 0.25;

    const pctMid = parseFloat(container.dataset.pctMid) || 0.27;

    const pctHigh = parseFloat(container.dataset.pctHigh) || 0.30;

   

    function animate(el, val, prefix = '₹') {

      let c = 0;

      const step = Math.max(1, Math.ceil(val / 30));

      const i = setInterval(() => {

        c += step;

        if (c >= val) {

          c = val;

          clearInterval(i);

        }

        el.textContent = prefix + c.toLocaleString('en-IN');

      }, 15);

    }

   

    function update() {

      const bill = parseInt(slider.value);

      let pct = pctBase;

     

      if (bill > 10000 && bill <= 50000) pct = pctMid;

      if (bill > 50000) pct = pctHigh;

     

      const monthly = Math.round(bill * pct);

      const yearly = monthly * 12;

      const newBill = bill - monthly;

      const roiMonths = Math.ceil(PRICE / monthly);

     

      display.textContent = bill.toLocaleString('en-IN');

      animate(mSaving, monthly);

      animate(ySaving, yearly);

      animate(nBill, newBill);

      roi.textContent = (isFinite(roiMonths) ? roiMonths : 0) + ' Mo';

    }

   

    slider.addEventListener('input', update);

    update();

  });

</script>



{% schema %}

{

  "name": "Savings Calculator",

  "settings": [

    {

      "type": "header",

      "content": "Fonts & Colors"

    },

    {

      "type": "font_picker",

      "id": "heading_font",

      "label": "Heading Font",

      "default": "work_sans_n9"

    },

    {

      "type": "font_picker",

      "id": "body_font",

      "label": "Body Font",

      "default": "work_sans_n4"

    },

    { "type": "color", "id": "color_green", "label": "Primary Green", "default": "#148C3A" },

    { "type": "color", "id": "color_green2", "label": "Secondary Green", "default": "#20b14b" },

    { "type": "color", "id": "color_orange", "label": "Orange", "default": "#F58220" },

    { "type": "color", "id": "color_text", "label": "Text Color", "default": "#1f2937" },

    { "type": "color", "id": "color_muted", "label": "Muted Text", "default": "#6b7280" },

    {

      "type": "header",

      "content": "Math & Logic"

    },

    { "type": "number", "id": "calc_price", "label": "Product Price (For ROI)", "default": 3498 },

    { "type": "number", "id": "pct_base", "label": "Base Saving % (<=10K)", "default": 25 },

    { "type": "number", "id": "pct_mid", "label": "Mid Saving % (10K-50K)", "default": 27 },

    { "type": "number", "id": "pct_high", "label": "High Saving % (>50K)", "default": 30 },

    { "type": "number", "id": "slider_min", "label": "Slider Minimum", "default": 500 },

    { "type": "number", "id": "slider_max", "label": "Slider Maximum", "default": 300000 },

    { "type": "number", "id": "slider_step", "label": "Slider Step", "default": 500 },

    { "type": "number", "id": "slider_default", "label": "Slider Default", "default": 4000 },

    {

      "type": "header",

      "content": "Text Content"

    },

    { "type": "text", "id": "tag_text", "label": "Tag Text", "default": "Smart Savings Calculator" },

    { "type": "text", "id": "heading_text", "label": "Heading Line 1", "default": "Calculate Your" },

    { "type": "text", "id": "heading_highlight", "label": "Heading Highlight", "default": "Electricity Savings" },

    { "type": "textarea", "id": "subheading_text", "label": "Subheading", "default": "Move the slider to estimate how much you can save every month with Vidhyut Saathi Smart Energy Saving Technology." },

    { "type": "text", "id": "slider_label", "label": "Slider Label", "default": "📄 Your Current Monthly Bill" },

    { "type": "text", "id": "label_monthly", "label": "Monthly Saving Label", "default": "Monthly Saving" },

    { "type": "text", "id": "label_yearly", "label": "Yearly Saving Label", "default": "Yearly Saving" },

    { "type": "text", "id": "label_newbill", "label": "New Bill Label", "default": "New Bill" },

    { "type": "text", "id": "label_roi", "label": "ROI Label", "default": "ROI" },

    { "type": "textarea", "id": "disclaimer_text", "label": "Disclaimer", "default": "Savings of 25–30% are estimated. Actual savings may vary based on usage patterns." }

  ],

  "blocks": [

    {

      "type": "trust_item",

      "name": "Trust Feature",

      "limit": 4,

      "settings": [

        { "type": "text", "id": "icon", "label": "Emoji/Icon", "default": "⚡" },

        { "type": "text", "id": "text", "label": "Text", "default": "Save Upto 30%" }

      ]

    }

  ],

  "presets": [

    {

      "name": "Premium Calculator",

      "blocks": [

        { "type": "trust_item", "settings": { "icon": "⚡", "text": "Save Upto 30%" } },

        { "type": "trust_item", "settings": { "icon": "🌿", "text": "Eco Friendly" } },

        { "type": "trust_item", "settings": { "icon": "⚙️", "text": "Smart Technology" } },

        { "type": "trust_item", "settings": { "icon": "🏆", "text": "Trusted Choice" } }

      ]

    }

  ]

}

{% endschema %}