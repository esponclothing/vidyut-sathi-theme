<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

{%- assign calc_font = section.settings.calc_font -%}

<style>
  /* Dynamically load selected font */
  {{ calc_font | font_face: font_display: 'swap' }}

  .vs-compact-calc-section {
    background-color: {{ section.settings.bg_color }};
    padding: 50px 5%;
    font-family: {{ calc_font.family }}, {{ calc_font.fallback_families }};
    overflow: hidden;
    display: flex;
    justify-content: center;
  }

  /* Main Dashboard Card */
  .vs-calc-dashboard {
    width: 100%;
    max-width: 1000px;
    background: #ffffff;
    border-radius: 24px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.08);
    border: 1px solid rgba(0,0,0,0.04);
    display: flex;
    flex-direction: row;
    overflow: hidden;
    opacity: 0;
    transform: translateY(30px);
    animation: vsFadeUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes vsFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* --- LEFT SIDE: INPUT & INFO --- */
  .vs-calc-left {
    flex: 1;
    padding: 40px;
    background: #ffffff;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .vs-calc-header h2 {
    color: {{ section.settings.text_color }};
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 800;
    line-height: 1.2;
    margin: 0 0 10px 0;
  }
  
  .vs-calc-header h2 span {
    color: {{ section.settings.primary_color }};
  }

  .vs-calc-header p {
    color: {{ section.settings.text_color }};
    opacity: 0.7;
    font-size: 15px;
    margin-bottom: 30px;
    line-height: 1.5;
  }

  .vs-input-group {
    background: #f8f9fa;
    border-radius: 16px;
    padding: 20px;
    border: 1px solid rgba(0,0,0,0.03);
    transition: all 0.3s ease;
  }
  
  .vs-input-group:focus-within {
    box-shadow: 0 10px 25px rgba(241, 126, 57, 0.15);
    border-color: {{ section.settings.primary_color }}50;
  }

  .vs-input-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 15px;
  }

  .vs-input-label {
    font-weight: 700;
    font-size: 14px;
    color: {{ section.settings.text_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .vs-currency-box {
    display: flex;
    align-items: center;
    background: #fff;
    border-radius: 10px;
    padding: 5px 12px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
  }

  .vs-currency-box span {
    font-size: 18px;
    font-weight: 700;
    color: {{ section.settings.primary_color }};
    margin-right: 5px;
  }

  .vs-currency-box input {
    border: none;
    background: transparent;
    font-size: 20px;
    font-weight: 800;
    color: {{ section.settings.text_color }};
    width: 90px;
    outline: none;
    font-family: inherit;
    padding: 0;
  }

  /* Custom Range Slider */
  .vs-slider {
    -webkit-appearance: none;
    width: 100%;
    height: 6px;
    background: #e0e0e0;
    border-radius: 4px;
    outline: none;
    cursor: pointer;
  }

  .vs-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: {{ section.settings.primary_color }};
    cursor: pointer;
    box-shadow: 0 4px 12px {{ section.settings.primary_color }}60;
    transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .vs-slider::-webkit-slider-thumb:hover {
    transform: scale(1.2);
  }

  /* --- RIGHT SIDE: RESULTS GRID --- */
  .vs-calc-right {
    flex: 1.2;
    background: #fafafa;
    padding: 40px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    border-left: 1px solid rgba(0,0,0,0.05);
  }

  .vs-res-item {
    background: #fff;
    border-radius: 16px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    box-shadow: 0 5px 15px rgba(0,0,0,0.03);
    border: 1px solid rgba(0,0,0,0.02);
    transition: transform 0.3s ease;
    text-align: center;
  }

  .vs-res-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.06);
  }

  .vs-res-label {
    font-size: 11px; /* Scaled down slightly to fit longer text */
    font-weight: 700;
    color: {{ section.settings.text_color }};
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }
  
  .vs-res-label i {
    color: {{ section.settings.secondary_color }};
    font-size: 14px;
  }

  .vs-res-val {
    font-size: 26px;
    font-weight: 800;
    color: {{ section.settings.text_color }};
    transition: color 0.3s;
  }

  .vs-res-approx {
    font-size: 11px;
    font-weight: 600;
    color: {{ section.settings.text_color }};
    opacity: 0.4;
    margin-top: 4px;
    text-transform: lowercase;
  }

  /* Highlight Item (Yearly) */
  .vs-res-item.highlight {
    background: linear-gradient(135deg, {{ section.settings.primary_color }}, {{ section.settings.secondary_color }});
    background-size: 200% 200%;
    animation: vsGradientShimmer 5s ease infinite;
    color: #fff;
    box-shadow: 0 15px 30px {{ section.settings.primary_color }}40;
    border: none;
  }

  @keyframes vsGradientShimmer {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .vs-res-item.highlight .vs-res-label {
    color: rgba(255,255,255,0.9);
    opacity: 1;
    font-size: 13px; /* Slightly larger for the highlight card */
  }
  
  .vs-res-item.highlight .vs-res-label i {
    color: #fff;
  }

  .vs-res-item.highlight .vs-res-val {
    color: #fff;
    font-size: 32px;
  }

  .vs-res-item.highlight .vs-res-approx {
    color: rgba(255,255,255,0.8);
    opacity: 1;
  }

  /* Number Update Bounce Animation */
  .vs-bounce {
    animation: vsBounceIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  @keyframes vsBounceIn {
    0% { transform: scale(1); }
    50% { transform: scale(1.08); color: {{ section.settings.primary_color }}; }
    100% { transform: scale(1); }
  }
  
  .vs-res-item.highlight .vs-bounce {
    animation: vsBounceInLight 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  @keyframes vsBounceInLight {
    0% { transform: scale(1); }
    50% { transform: scale(1.08); text-shadow: 0 0 10px rgba(255,255,255,0.8); }
    100% { transform: scale(1); }
  }

  /* --- MOBILE RESPONSIVE --- */
  @media screen and (max-width: 800px) {
    .vs-calc-dashboard {
      flex-direction: column;
    }
    .vs-calc-left, .vs-calc-right {
      padding: 30px 20px;
    }
    .vs-calc-right {
      border-left: none;
      border-top: 1px solid rgba(0,0,0,0.05);
    }
    .vs-res-val {
      font-size: 22px;
    }
    .vs-res-item.highlight .vs-res-val {
      font-size: 28px;
    }
  }
</style>

<div class="vs-compact-calc-section" id="section-{{ section.id }}">
  <div class="vs-calc-dashboard">
    
    <!-- Left: Inputs -->
    <div class="vs-calc-left">
      <div class="vs-calc-header">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.description }}</p>
      </div>

      <div class="vs-input-group">
        <div class="vs-input-top">
          <span class="vs-input-label">Avg. Monthly Bill</span>
          <div class="vs-currency-box">
            <span>₹</span>
            <input type="number" id="vs-input-{{ section.id }}" value="3500" min="500" max="50000" step="100">
          </div>
        </div>
        
        <input type="range" id="vs-slider-{{ section.id }}" class="vs-slider" min="500" max="50000" step="100" value="3500">
        
        <div style="display: flex; justify-content: space-between; margin-top: 12px; font-size: 12px; color: #aaa; font-weight: 600;">
          <span>₹500</span>
          <span>₹50k+</span>
        </div>
      </div>
    </div>

    <!-- Right: Results -->
    <div class="vs-calc-right">
      
      <div class="vs-res-item">
        <div class="vs-res-label"><i class="fas fa-wallet"></i> Total Monthly Saving</div>
        <div class="vs-res-val" id="vs-val-mo-{{ section.id }}">₹0</div>
        <div class="vs-res-approx">approx.</div>
      </div>

      <div class="vs-res-item">
        <div class="vs-res-label"><i class="fas fa-chart-pie"></i> Total Quarterly Saving</div>
        <div class="vs-res-val" id="vs-val-qt-{{ section.id }}">₹0</div>
        <div class="vs-res-approx">approx.</div>
      </div>

      <div class="vs-res-item">
        <div class="vs-res-label"><i class="fas fa-calendar-alt"></i> Total Half-Yearly Saving</div>
        <div class="vs-res-val" id="vs-val-hy-{{ section.id }}">₹0</div>
        <div class="vs-res-approx">approx.</div>
      </div>

      <div class="vs-res-item highlight">
        <div class="vs-res-label"><i class="fas fa-piggy-bank"></i> Total Yearly Saving</div>
        <div class="vs-res-val" id="vs-val-yr-{{ section.id }}">₹0</div>
        <div class="vs-res-approx">approx.</div>
      </div>

    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sId = '{{ section.id }}';
    const input = document.getElementById(`vs-input-${sId}`);
    const slider = document.getElementById(`vs-slider-${sId}`);
    
    const valMo = document.getElementById(`vs-val-mo-${sId}`);
    const valQt = document.getElementById(`vs-val-qt-${sId}`);
    const valHy = document.getElementById(`vs-val-hy-${sId}`);
    const valYr = document.getElementById(`vs-val-yr-${sId}`);

    // Set specifically to exactly 18% saving
    const savingsRate = {{ section.settings.savings_percentage | divided_by: 100.0 }};

    function formatAmt(amount) {
      return '₹' + amount.toLocaleString('en-IN', { maximumFractionDigits: 0 });
    }

    function triggerBounce(el) {
      el.classList.remove('vs-bounce');
      void el.offsetWidth; // Force DOM reflow
      el.classList.add('vs-bounce');
    }

    function calcAndUpdate() {
      let bill = parseFloat(input.value) || 0;
      
      // Strict 18% multiplier logic (calculates the SAVED value, not the remaining bill)
      let monthly = bill * savingsRate;
      let quarterly = monthly * 3;
      let halfYearly = monthly * 6;
      let yearly = monthly * 12;

      // Update Text Values
      valMo.innerText = formatAmt(monthly);
      valQt.innerText = formatAmt(quarterly);
      valHy.innerText = formatAmt(halfYearly);
      valYr.innerText = formatAmt(yearly);

      // Trigger Animations
      triggerBounce(valMo);
      triggerBounce(valQt);
      triggerBounce(valHy);
      triggerBounce(valYr);

      // Slider Fill
      const pct = ((slider.value - slider.min) / (slider.max - slider.min)) * 100;
      slider.style.background = `linear-gradient(to right, {{ section.settings.primary_color }} ${pct}%, #e0e0e0 ${pct}%)`;
    }

    // Interactions
    slider.addEventListener('input', function() {
      input.value = this.value;
      calcAndUpdate();
    });

    input.addEventListener('change', function() {
      if(this.value > 50000) this.value = 50000;
      if(this.value < 500) this.value = 500;
      slider.value = this.value;
      calcAndUpdate();
    });

    // Run on load
    calcAndUpdate();
  });
</script>

{% schema %}
{
  "name": "Compact Savings Calc",
  "settings": [
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Calculate Your <span>Savings</span>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "See how much you save on average (approx 18%) by switching to smart energy solutions with Vidhyut Saathi."
    },
    {
      "type": "range",
      "id": "savings_percentage",
      "min": 5,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Estimated Savings Rate",
      "info": "Set the average % saved on monthly bills (Defaults to 18%).",
      "default": 18
    },
    {
      "type": "header",
      "content": "Design & Fonts"
    },
    {
      "type": "font_picker",
      "id": "calc_font",
      "label": "Section Font",
      "default": "helvetica_n4"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4f7f6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Accent (Orange)",
      "default": "#F17E39"
    },
    {
      "type": "color",
      "id": "secondary_color",
      "label": "Secondary Accent (Green)",
      "default": "#007B3E"
    }
  ],
  "presets": [
    {
      "name": "Compact Savings Calc"
    }
  ]
}
{% endschema %}