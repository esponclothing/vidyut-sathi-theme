{%- doc -%}
  Renders the cart summary totals.

  @param {string} [accelerated_checkout_buttons_layout] - { 'vertical' } Forced layout of the additional checkout buttons, instead of relying on platform's layout.
  @param {string} [section_id] - The section ID for cart discount component.
{%- enddoc -%}

<div class="cart-totals">
  {% # We need to keep this node in place to allow morphing to work properly # %}
  <div class="cart-totals__original-container cart-primary-typography">
    {%- if cart.cart_level_discount_applications.size > 0 -%}
      <span class="cart-totals__item cart-totals__original">
        <span class="cart-totals__original-label">{{ 'content.cart_subtotal' | t }}</span>
        <span
          class="cart-totals__original-value cart-secondary-typography"
          data-testid="cart-subtotal-value"
        >
          {{- cart.items_subtotal_price | money -}}
        </span>
      </span>
      <ul
        class="cart-discounts"
        role="list"
        aria-label="{{ 'content.discounts' | t }}"
      >
        {%- for discount in cart.cart_level_discount_applications -%}
          <li class="cart-discounts__item">
            <span class="cart-discounts__label">
              {{- 'icon-discount.svg' | inline_asset_content -}}
              {{ discount.title | escape }}
            </span>
            <span class="cart-discounts__value cart-secondary-typography"
              >-{{ discount.total_allocated_amount | money -}}
            </span>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>

  {% if settings.show_cart_note or settings.show_add_discount_code %}
    <div class="cart-actions">
      {% if settings.show_cart_note %}
        <script
          type="module"
          src="{{ 'cart-note.js' | asset_url }}"
        ></script>

        <cart-note style="display: flex;">
          {% capture cart_note_accordion_children %}
            <details
              class="details"
              {% if settings.cart_note_open_by_default %}
                open
              {% endif %}
            >
              <summary class="cart-note__summary">
                <span class="cart-note__label cart-primary-typography">
                  {{ 'content.seller_note' | t }}
                </span>

                <span class="cart-totals__icon">
                  {{- 'icon-plus.svg' | inline_asset_content -}}
                </span>
              </summary>

              <div class="details-content cart-note__inner">
                <label
                  for="cart-note"
                  class="visually-hidden"
                >
                  {{- 'content.seller_note' | t -}}
                </label>
                <textarea
                  form="cart-form"
                  on:input="/updateCartNote"
                  id="cart-note"
                  class="cart-note__instructions"
                  name="note"
                >{{ cart.note }}</textarea>
              </div>
            </details>
          {% endcapture %}
          {% render 'accordion-custom-component',
            children: cart_note_accordion_children,
            class: 'cart-note',
            open_by_default_on_desktop: settings.cart_note_open_by_default,
            open_by_default_on_mobile: settings.cart_note_open_by_default
          %}
        </cart-note>
      {% endif %}
      {% if settings.show_cart_note and settings.show_add_discount_code %}
        <div class="cart-actions__divider"></div>
      {% endif %}
      {% liquid
        assign show_coupons = false
        if show_coupon_offers
          if section_settings == nil
            assign show_coupons = true
          elsif section_settings.show_coupon_section
            assign show_coupons = true
          endif
        endif
      %}
      {% if show_coupons %}
        {% liquid
          assign discount_codes = cart.cart_level_discount_applications | where: 'type', 'discount_code' | map: 'title'
          for item in cart.items
            for allocation in item.line_level_discount_allocations
              if allocation.discount_application.type == 'discount_code'
                assign discount_codes = item.line_level_discount_allocations | slice: forloop.index0 | map: 'discount_application' | map: 'title' | concat: discount_codes
              endif
            endfor
          endfor

          assign discount_codes = discount_codes | uniq
        %}

        <style>
          .lx-coupon-section {
            margin-bottom: 20px;
            padding-bottom: 20px;
            border-bottom: 1px dashed var(--color-border);
          }
          .lx-coupon-label {
            font-size: 13px;
            font-weight: 600;
            color: var(--color-foreground);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-top: 0;
          }
          .lx-coupon-label svg {
            color: var(--color-primary, #b89356);
          }
          .lx-coupon-input-row {
            display: flex;
            gap: 8px;
            margin-bottom: 10px;
          }
          .lx-coupon-input {
            flex: 1;
            border: 1px solid var(--color-border);
            border-radius: var(--style-border-radius-inputs, 4px);
            padding: 10px 14px;
            font-size: 13px;
            font-weight: 500;
            text-transform: uppercase;
            color: var(--color-foreground);
            outline: none;
            min-width: 0;
            background: var(--color-input-background, #fff);
            transition: border-color 0.2s ease;
          }
          .lx-coupon-input:focus {
            border-color: var(--color-primary, #b89356);
          }
          .lx-coupon-input::placeholder {
            letter-spacing: 0;
            text-transform: none;
            opacity: 0.6;
          }
          .lx-coupon-apply-btn {
            background: var(--color-foreground) !important;
            color: var(--color-background) !important;
            border: none;
            border-radius: var(--style-border-radius-inputs, 4px);
            padding: 0 20px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            flex-shrink: 0;
            transition: opacity 0.2s ease;
          }
          .lx-coupon-apply-btn:hover {
            opacity: 0.9;
          }
          .lx-coupon-error-msg {
            font-size: 12px;
            color: #EF4444;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 5px;
          }
          .lx-applied-coupon {
            background: #ECFDF5;
            border: 1px solid #A7F3D0;
            border-radius: 6px;
            padding: 12px 14px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            list-style: none;
          }
          .lx-applied-left {
            display: flex;
            flex-direction: column;
            gap: 2px;
          }
          .lx-applied-code {
            font-size: 14px;
            font-weight: 700;
            color: #065F46;
            display: flex;
            align-items: center;
            gap: 6px;
          }
          .lx-applied-code svg {
            color: #10B981;
          }
          .lx-applied-desc {
            font-size: 11px;
            color: #047857;
          }
          .lx-remove-coupon-btn {
            background: none;
            border: 1px solid #FCA5A5;
            border-radius: 4px;
            color: #DC2626;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            padding: 5px 12px;
            transition: all 0.2s ease;
          }
          .lx-remove-coupon-btn:hover {
            background: #FEF2F2;
          }
          .lx-offers-label {
            font-size: 11px;
            font-weight: 600;
            color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 15px;
            margin-bottom: 10px;
          }
          .lx-offers-scroll {
            display: flex;
            flex-direction: column;
            gap: 8px;
            max-height: 220px;
            overflow-y: auto;
            padding-right: 4px;
          }
          .lx-offers-scroll::-webkit-scrollbar {
            width: 4px;
          }
          .lx-offers-scroll::-webkit-scrollbar-thumb {
            background: var(--color-border);
            border-radius: 4px;
          }
          .lx-offer-card {
            border: 1px dashed var(--color-border);
            border-radius: 6px;
            padding: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgb(var(--color-foreground-rgb) / 0.02);
            transition: border-color 0.2s ease, background 0.2s ease;
            gap: 12px;
          }
          .lx-offer-card:hover {
            border-color: var(--color-primary, #b89356);
            background: rgb(var(--color-foreground-rgb) / 0.04);
          }
          .lx-offer-card.highlight-offer {
            border-color: var(--color-primary, #b89356);
            background: rgb(var(--color-foreground-rgb) / 0.03);
          }
          .lx-offer-details {
            flex: 1;
            min-width: 0;
            display: flex;
            flex-direction: column;
            gap: 4px;
          }
          .lx-offer-code {
            font-size: 13px;
            font-weight: 700;
            color: var(--color-foreground);
            display: flex;
            align-items: center;
            gap: 6px;
          }
          .lx-offer-code svg {
            color: var(--color-primary, #b89356);
          }
          .lx-offer-desc {
            font-size: 11px;
            color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
          }
          .lx-offer-apply-btn {
            font-size: 11px;
            font-weight: 700;
            color: var(--color-primary, #b89356);
            background: none;
            border: 1px solid var(--color-primary, #b89356);
            border-radius: 4px;
            cursor: pointer;
            padding: 4px 12px;
            white-space: nowrap;
            transition: all 0.2s ease;
          }
          .lx-offer-apply-btn:hover {
            background: var(--color-primary, #b89356);
            color: var(--color-background);
          }
          .lx-offer-locked-msg {
            font-size: 11px;
            color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
            white-space: nowrap;
          }
        </style>

        <div class="lx-coupon-section">
          <p class="lx-coupon-label">
            <svg class="lx-tag-icon" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" style="vertical-align: middle;">
              <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
              <line x1="7" y1="7" x2="7.01" y2="7"></line>
            </svg>
            <span>{{ section_settings.coupon_title | default: 'Coupons & Offers' }}</span>
          </p>

          <cart-discount-component
            {% if section_id != blank %}
              data-section-id="{{ section_id }}"
            {% endif %}
          >
            {% if discount_codes.size > 0 %}
              <ul class="lx-applied-coupons-list" style="list-style:none; padding:0; margin:0 0 10px 0;">
                {% for discount_code in discount_codes %}
                  <li
                    class="cart-discount__pill lx-applied-coupon"
                    data-discount-code="{{ discount_code }}"
                  >
                    <div class="lx-applied-left">
                      <div class="lx-applied-code">
                        <svg class="lx-check-icon" viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
                          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                        </svg>
                        <span>{{ discount_code }}</span>
                      </div>
                      <span class="lx-applied-desc">Coupon Applied Successfully!</span>
                    </div>
                    <button
                      type="button"
                      on:click="/removeDiscount"
                      class="lx-remove-coupon-btn"
                      aria-label="Remove Coupon"
                    >
                      Remove
                    </button>
                  </li>
                {% endfor %}
              </ul>
            {% else %}
              <div class="cart-discount__content">
                <form
                  on:submit="/applyDiscount"
                  onsubmit="return false;"
                  class="lx-coupon-form"
                >
                  <div class="lx-coupon-input-row">
                    <input
                      id="cart-discount"
                      class="lx-coupon-input"
                      type="text"
                      name="discount"
                      placeholder="Enter coupon code"
                      autocomplete="off"
                      required
                    >
                    <button type="submit" class="lx-coupon-apply-btn">Apply</button>
                  </div>
                </form>
              </div>
            {% endif %}

            <div
              class="cart-discount__error hidden"
              role="alert"
              ref="cartDiscountError"
            >
              <div class="lx-coupon-error-msg">
                <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="12" y1="8" x2="12" y2="12"></line>
                  <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
                <span
                  class="cart-discount__error-text hidden"
                  ref="cartDiscountErrorDiscountCode"
                >
                  {{ 'content.discount_code_error' | t: code: 'test' }}
                </span>
                <span
                  class="cart-discount__error-text hidden"
                  ref="cartDiscountErrorShipping"
                >
                  {{ 'content.shipping_discount_error' | t }}
                </span>
              </div>
            </div>

            {% assign has_coupons = false %}
            {% for block in coupon_blocks %}
              {% if block.type == 'coupon' %}
                {% assign has_coupons = true %}
              {% endif %}
            {% endfor %}

            {% if section_settings == nil or section_settings.show_available_offers %}
              {% if has_coupons %}
                <p class="lx-offers-label">{{ section_settings.offers_label | default: 'Available Offers' }}</p>
                <div class="lx-offers-scroll">
                  {% for block in coupon_blocks %}
                    {% if block.type == 'coupon' %}
                      {% assign min_spend = block.settings.min_spend %}
                      {% assign min_spend_cents = min_spend | times: 100 %}
                      {% assign cart_total = cart.total_price %}
                      {% assign is_eligible = false %}
                      {% if cart_total >= min_spend_cents %}
                        {% assign is_eligible = true %}
                      {% endif %}
                      
                      <div class="lx-offer-card{% if block.settings.highlight %} highlight-offer{% endif %}">
                        <div class="lx-offer-details">
                          <span class="lx-offer-code">
                            <svg class="lx-tag-icon" viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none">
                              <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                              <line x1="7" y1="7" x2="7.01" y2="7"></line>
                            </svg>
                            {{ block.settings.code }}
                          </span>
                          <span class="lx-offer-desc">{{ block.settings.desc }}</span>
                        </div>
                        {% if is_eligible %}
                          <button type="button" class="lx-offer-apply-btn" onclick="applyCouponCode('{{ block.settings.code }}')">APPLY</button>
                        {% else %}
                          {% assign diff_amount = min_spend_cents | minus: cart_total | divided_by: 100.0 | round %}
                          <span class="lx-offer-locked-msg">🔒 Add ₹{{ diff_amount }}</span>
                        {% endif %}
                      </div>
                    {% endif %}
                  {% endfor %}
                </div>
              {% else %}
                <p class="lx-offers-label">{{ section_settings.offers_label | default: 'Available Offers' }}</p>
                <div class="lx-offers-scroll">
                  {% assign mock_codes = "WELCOME10,SAVE20,FESTIVE30" | split: "," %}
                  {% assign mock_min_spends = "500,999,1999" | split: "," %}
                  {% assign mock_descs = "Get Flat 10% off on orders above ₹500,Get Flat 20% off on orders above ₹999,Get Flat 30% off on orders above ₹1999" | split: "," %}
                  {% assign mock_highlights = "true,false,false" | split: "," %}
                  
                  {% for code in mock_codes %}
                    {% assign idx = forloop.index0 %}
                    {% assign min_spend = mock_min_spends[idx] | plus: 0 %}
                    {% assign min_spend_cents = min_spend | times: 100 %}
                    {% assign cart_total = cart.total_price %}
                    {% assign is_eligible = false %}
                    {% if cart_total >= min_spend_cents %}
                      {% assign is_eligible = true %}
                    {% endif %}
                    {% assign highlight = mock_highlights[idx] %}
                    
                    <div class="lx-offer-card{% if highlight == 'true' %} highlight-offer{% endif %}">
                      <div class="lx-offer-details">
                        <span class="lx-offer-code">
                          <svg class="lx-tag-icon" viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none">
                            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                            <line x1="7" y1="7" x2="7.01" y2="7"></line>
                          </svg>
                          {{ code }}
                        </span>
                        <span class="lx-offer-desc">{{ mock_descs[idx] }}</span>
                      </div>
                      {% if is_eligible %}
                        <button type="button" class="lx-offer-apply-btn" onclick="applyCouponCode('{{ code }}')">APPLY</button>
                      {% else %}
                        {% assign diff_amount = min_spend_cents | minus: cart_total | divided_by: 100.0 | round %}
                        <span class="lx-offer-locked-msg">🔒 Add ₹{{ diff_amount }}</span>
                      {% endif %}
                    </div>
                  {% endfor %}
                </div>
              {% endif %}
            {% endif %}

          </cart-discount-component>
        </div>

        <script>
          window.applyCouponCode = function(code) {
            const input = document.querySelector('.lx-coupon-input');
            if (input) {
              input.value = code;
              const form = input.closest('form');
              if (form) {
                const event = new Event('submit', { bubbles: true, cancelable: true });
                form.dispatchEvent(event);
              }
            }
          }
        </script>

      {% elsif settings.show_add_discount_code %}
        {% liquid
          assign discount_codes = cart.cart_level_discount_applications | where: 'type', 'discount_code' | map: 'title'
          for item in cart.items
            for allocation in item.line_level_discount_allocations
              if allocation.discount_application.type == 'discount_code'
                assign discount_codes = item.line_level_discount_allocations | slice: forloop.index0 | map: 'discount_application' | map: 'title' | concat: discount_codes
              endif
            endfor
          endfor

          assign discount_codes = discount_codes | uniq

          # Evaluate the boolean expression for the disclosure state
          if discount_codes.size == 0
            assign disclosure_expanded = false
          else
            assign disclosure_expanded = true
          endif
        %}

        {% capture cart_discount_accordion_children %}
          <details
            class="details"
            {% if disclosure_expanded %}
              open
            {% endif %}
          >
            <summary class="cart-discount__summary">
              <span class="cart-discount__label cart-primary-typography">{{ 'content.discount' | t }}</span>

              <span class="cart-totals__icon">
                {{- 'icon-plus.svg' | inline_asset_content -}}
              </span>
            </summary>

            <div class="details-content">
              <div id="cart-discount-disclosure">
                <cart-discount-component
                  {% if section_id != blank %}
                    data-section-id="{{ section_id }}"
                  {% endif %}
                >
                  <div class="cart-discount__content">
                    <form
                      on:submit="/applyDiscount"
                      onsubmit="return false;"
                      class="cart-discount__form"
                    >
                      <label
                        for="cart-discount"
                        class="visually-hidden"
                      >
                        {{- 'accessibility.discount' | t -}}
                      </label>
                      <input
                        id="cart-discount"
                        class="cart-discount__input"
                        type="text"
                        name="discount"
                        size="8"
                        placeholder="{{ 'content.discount_code' | t }}"
                        required
                      >
                      <button
                        type="submit"
                        class="button cart-discount__button"
                      >
                        {{ 'actions.apply' | t }}
                      </button>
                    </form>
                  </div>
                  <div
                    class="cart-discount__error hidden"
                    role="alert"
                    ref="cartDiscountError"
                  >
                    <span class="svg-wrapper">
                      {{- 'icon-error.svg' | inline_asset_content -}}
                    </span>
                    <small
                      class="cart-discount__error-text cart-primary-typography hidden"
                      ref="cartDiscountErrorDiscountCode"
                    >
                      {{ 'content.discount_code_error' | t: code: 'test' }}
                    </small>
                    <small
                      class="cart-discount__error-text cart-primary-typography hidden"
                      ref="cartDiscountErrorShipping"
                    >
                      {{ 'content.shipping_discount_error' | t }}
                    </small>
                  </div>
                  <ul class="cart-discount__codes">
                    {% for discount_code in discount_codes %}
                      <li
                        class="cart-discount__pill"
                        data-discount-code="{{ discount_code }}"
                        aria-label="{{ 'accessibility.discount_applied' | t: code: discount_code }}"
                      >
                        <p class="cart-discount__pill-code">
                          {{ discount_code }}
                        </p>
                        <button
                          type="button"
                          on:click="/removeDiscount"
                          class="cart-discount__pill-remove svg-wrapper svg-wrapper--smaller button-unstyled"
                          aria-label="{{ 'actions.remove_discount' | t: code: discount_code }}"
                        >
                          {{- 'icon-filters-close.svg' | inline_asset_content -}}
                        </button>
                      </li>
                    {% endfor %}
                  </ul>
                </cart-discount-component>
              </div>
            </div>
          </details>
        {% endcapture %}
        {% render 'accordion-custom-component',
          children: cart_discount_accordion_children,
          class: 'cart-discount'
        %}
      {% endif %}
    </div>
  {% endif %}

  {%- liquid
    if settings.currency_code_enabled_cart_total
      assign total_price = cart.total_price | money_with_currency
    else
      assign total_price = cart.total_price | money
    endif
  -%}

  <div class="cart-totals__container{% if settings.show_installments %} cart-totals__container--has-installments{% endif %}">
    <span
      class="cart-totals__item cart-totals__total"
      role="status"
    >
      <span class="cart-totals__total-label cart-primary-typography">{{ 'content.cart_estimated_total' | t }}</span>
      <text-component
        ref="cartTotal"
        value="{{ total_price | strip_html }}"
        class="cart-totals__total-value cart-secondary-typography"
        {% comment %} Used by payment_terms web component {% endcomment %}
        data-testid="cart-total-value"
        data-cart-subtotal
      >
        {{ total_price }}
      </text-component>
    </span>
    {% if settings.show_installments %}
      <span class="cart-totals__item cart-totals__installments">
        {% form 'cart', cart %}
          {{ form | payment_terms }}
        {% endform %}
      </span>
    {% endif %}
    <div class="cart-totals__item cart-totals__tax-note cart-primary-typography">
      {% render 'tax-info', has_discounts_enabled: settings.show_add_discount_code %}
    </div>
  </div>
</div>

<div class="cart__ctas">
  <button
    type="submit"
    id="checkout"
    class="cart__checkout-button button"
    name="checkout"
    {% if cart == empty %}
      disabled
    {% endif %}
    form="cart-form"
  >
    <span class="button-text">
      {{ 'content.checkout' | t }}
    </span>
  </button>

  {% if additional_checkout_buttons and settings.show_accelerated_checkout_buttons %}
    <div
      class="
        additional-checkout-buttons
        {% if accelerated_checkout_buttons_layout == 'vertical' %}additional-checkout-buttons--vertical{% endif %}
      "
    >
      {{ content_for_additional_checkout_buttons }}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .cart-actions {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-block: 1px solid var(--color-border);
    padding-block: 0;
    margin-block-start: var(--margin-3xs);
  }

  .cart-actions__divider {
    border-block-start: 1px solid var(--color-border);
  }

  .cart-totals:not(:has(.cart-actions)) {
    margin-block-start: var(--margin-3xs);
    border-block-start: 1px solid var(--color-border);
    padding-block-start: var(--margin-xl);
  }

  .cart-totals__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cart-totals__tax-note {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .cart-totals__tax-note small {
    font-size: var(--font-size--2xs);
  }

  .cart-discounts {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cart-discounts__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cart-discounts__label {
    display: flex;
    align-items: center;
    gap: var(--gap-2xs);
  }

  .cart-discounts__label svg {
    width: var(--icon-size-sm);
    height: var(--icon-size-sm);
    display: inline-block;
  }

  .cart-totals__original-container,
  .cart-totals__container {
    display: flex;
    flex-direction: column;
  }

  .cart-totals__container {
    row-gap: var(--gap-2xs);

    &.cart-totals__container--has-installments {
      row-gap: var(--gap-xs);
    }
  }

  .cart-totals__original-container:empty {
    display: none;
  }

  .cart-totals {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xl);
    width: 100%;
    border-block-start: none;

    &:has(> :first-child:not(.cart-totals__original-container, .cart-totals__container)) {
      padding-block-start: 0;
      border-block-start: none;
    }

    @media screen and (min-width: 750px) {
      padding-block-start: 0;
    }
  }

  .cart-totals__original-container,
  .cart-totals__original-container * {
    font-size: var(--cart-font-size--sm);
  }

  .cart-totals__total {
    align-items: baseline;
    font-weight: var(--font-weight-bold);
  }

  .cart-totals__total-label {
    font-size: var(--cart-font-size--sm);
  }

  .cart-totals__total-value {
    font-size: var(--cart-font-size--xl);

    @media screen and (max-width: 749px) {
      font-size: var(--font-size--lg);
    }
  }

  .cart-totals__installments {
    color: var(--color-foreground);
    font-size: var(--font-size--2xs);
  }

  .cart-note {
    width: 100%;
  }

  @starting-style {
    .cart-note[open-by-default-on-desktop][open-by-default-on-mobile] .details-content {
      block-size: auto;
      opacity: 1;
      overflow-y: visible;
    }
  }

  .cart-note__inner {
    padding-block: var(--padding-2xs) var(--padding-sm);
  }

  .cart-note__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cart-note__summary:hover {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .cart-note__label {
    display: flex;
    align-items: flex-start;
    gap: var(--gap-2xs);
    font-size: var(--font-size--2xs);
    font-weight: 500;
  }

  .cart-note__instructions {
    color: var(--color-input-text);
    background-color: var(--color-input-background);
    border-width: var(--style-border-width-inputs);
    border-color: var(--color-input-border);
    transition: box-shadow var(--animation-speed) ease;
    box-shadow: var(--input-box-shadow);
    min-height: 5.5rem;
    min-width: 100%;
    max-width: 100%;
    font-size: var(--font-size--sm);
    padding: max(4px, calc(var(--style-border-radius-inputs) * (1 - cos(45deg))));
  }

  .cart-totals__icon {
    height: var(--icon-size-xs);
    width: var(--icon-size-xs);
    margin: 0;
  }

  .cart__ctas {
    width: 100%;
    display: grid;
    gap: var(--checkout-button-gap);
    grid-auto-flow: row;
    grid-template-columns: 1fr;
  }

  .cart__ctas .cart__checkout-button {
    width: 100%;
    height: clamp(25px, var(--height-buy-buttons), 55px);
    padding-inline: var(--padding-4xl);
  }

  .cart-drawer__summary .cart-totals:not(:has(.cart-totals__original-container:empty)) {
    border-block-start: var(--style-border-width) solid var(--color-border);
    padding-block-start: var(--padding-2xl);
  }

  .cart-drawer__summary .cart-note {
    @media screen and (min-width: 750px) {
      margin-block-start: var(--margin-3xs);
    }
  }

  .cart-discount__input {
    background-color: var(--color-input-background);
    color: var(--color-input-text);
    border-width: var(--style-border-width-inputs);
    border-color: var(--color-input-border);
    border-style: solid;
    border-radius: var(--style-border-radius-inputs);
    padding: var(--padding-sm) var(--padding-md);
    height: 100%;
    flex-grow: 1;
    min-width: 0;
    font-size: var(--font-size--sm);
  }

  .cart-discount__input::placeholder {
    color: rgb(var(--color-input-text-rgb) / var(--opacity-subdued-text));
  }

  .cart-discount__pill-code {
    overflow: hidden;
    max-width: 100px;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin: 0;
  }

  .cart-discount {
    width: 100%;
  }

  .cart-discount__codes {
    display: none;
    gap: var(--padding-xs);
    flex-wrap: wrap;
    list-style: none;
    padding-inline: 0;
    margin: 0;
  }

  .cart-discount__codes:has(.cart-discount__pill) {
    display: flex;
  }

  .cart-discount__button {
    height: 100%;
  }

  .cart-discount__content {
    height: calc(var(--button-size) + var(--padding-2xs) + var(--padding-sm));
  }

  .cart-discount__pill {
    display: flex;
    color: var(--color-foreground);
    gap: var(--padding-xs);
    align-items: center;
    padding: var(--padding-xs) var(--padding-sm);
    border-radius: var(--style-border-radius-pills);
    background-color: var(--color-input-background);
    text-transform: uppercase;
  }

  .cart-discount__form {
    display: flex;
    gap: var(--padding-md);
    align-items: center;
    height: 100%;
    padding-block: var(--padding-2xs) var(--padding-sm);
  }

  :is(.cart-discount__pill-remove, .cart-discount__pill-remove:hover) {
    --close-icon-opacity: 0.4;

    color: var(--color-foreground);
    background-color: transparent;
    pointer-events: all;
    cursor: pointer;
    height: 100%;
  }

  .cart-discount__error {
    display: flex;
    align-items: center;
    width: 100%;
    padding-block: var(--padding-2xs) var(--padding-sm);
  }

  .cart-discount__error .svg-wrapper {
    flex-shrink: 0;
    width: var(--icon-size-xs);
    height: var(--icon-size-xs);
    margin-inline: var(--margin-3xs) var(--margin-xs);
  }

  .cart-discount__error-text {
    margin-block-start: var(--margin-3xs);
  }

  .cart-discount__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cart-discount__summary:hover {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .cart-discount__label {
    display: flex;
    align-items: flex-start;
    gap: var(--gap-2xs);
    font-size: var(--font-size--2xs);
    font-weight: 500;
  }

  @media screen and (min-width: 750px) {
    .cart-summary--extend {
      height: 100%;
    }
  }
{% endstylesheet %}
